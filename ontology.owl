        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000219"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">16.01</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.1</skos:notation>
        <skos:note xml:lang="fr">Cible 16.1</skos:note>
        <skos:note xml:lang="es">Meta 16.1</skos:note>
        <skos:note xml:lang="en">Target 16.1</skos:note>
        <skos:prefLabel xml:lang="es">Reducir significativamente todas las formas de violencia y las correspondientes tasas de mortalidad en todo el mundo</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Réduire nettement, partout dans le monde, toutes les formes de violence et les taux de mortalité qui y sont associés</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Significantly reduce all forms of violence and related death rates everywhere</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.10 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.10">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
