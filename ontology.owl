        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1007029"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/3"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030101"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030102"/>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000086"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">03.01</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.1</skos:notation>
        <skos:note xml:lang="fr">Cible 3.1</skos:note>
        <skos:note xml:lang="es">Meta 3.1</skos:note>
        <skos:note xml:lang="en">Target 3.1</skos:note>
        <skos:prefLabel xml:lang="en">By 2030, reduce the global maternal mortality ratio to less than 70 per 100,000 live births</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2030, reducir la tasa mundial de mortalidad materna a menos de 70 por cada 100.000 nacidos vivos</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2030, faire passer le taux mondial de mortalité maternelle au-dessous de 70 pour 100 000 naissances vivantes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.2 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.2">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030201"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030202"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/3"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/1991"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/5291"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1000937"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1000952"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1001518"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1004239"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/3"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030201"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030202"/>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000087"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">03.02</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.2</skos:notation>
        <skos:note xml:lang="fr">Cible 3.2</skos:note>
        <skos:note xml:lang="es">Meta 3.2</skos:note>
        <skos:note xml:lang="en">Target 3.2</skos:note>
        <skos:prefLabel xml:lang="en">By 2030, end preventable deaths of newborns and children under 5 years of age, with all countries aiming to reduce neonatal mortality to at least as low as 12 per 1,000 live births and under‑5 mortality to at least as low as 25 per 1,000 live births</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2030, poner fin a las muertes evitables de recién nacidos y de niños menores de 5 años, logrando que todos los países intenten reducir la mortalidad neonatal al menos a 12 por cada 1.000 nacidos vivos y la mortalidad de los niños menores de 5 años al menos a 25 por cada 1.000 nacidos vivos</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2030, éliminer les décès évitables de nouveau-nés et d’enfants de moins de 5 ans, tous les pays devant chercher à ramener la mortalité néonatale à 12 pour 1 000 naissances vivantes au plus et la mortalité des enfants de moins de 5 ans à 25 pour 1 000 naissances vivantes au plus</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.3 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.3">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030301"/>
