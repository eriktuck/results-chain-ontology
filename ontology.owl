        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.5</skos:notation>
        <skos:note xml:lang="fr">Cible 3.5</skos:note>
        <skos:note xml:lang="es">Meta 3.5</skos:note>
        <skos:note xml:lang="en">Target 3.5</skos:note>
        <skos:prefLabel xml:lang="es">Fortalecer la prevención y el tratamiento del abuso de sustancias adictivas, incluido el uso indebido de estupefacientes y el consumo nocivo de alcohol</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Renforcer la prévention et le traitement de l’abus de substances psychoactives, notamment de stupéfiants et d’alcool</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Strengthen the prevention and treatment of substance abuse, including narcotic drug abuse and harmful use of alcohol</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.6 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.6">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
