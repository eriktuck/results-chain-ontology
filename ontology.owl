        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.b"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.c"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.1"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.2"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.3"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.4"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.5"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.6"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/11.7"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/4809"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1000995"/>
