        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Thin trees within forests</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1492 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1492">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Manually control or remove secondary mid-storey and ground-level vegetation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1493 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1493">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
