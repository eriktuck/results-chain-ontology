<?xml version="1.0"?>
<rdf:RDF xmlns="https://eriktuck.github.io/results-chain-ontology/"
     xml:base="https://eriktuck.github.io/results-chain-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/"
     xmlns:ontology="http://metadata.un.org/sdg/ontology#">
    <owl:Ontology rdf:about="https://eriktuck.github.io/results-chain-ontology/">
        <rdfs:comment>A simple ontology based on Margoluis et al. (2013) to represent Theories of Change in conservation.</rdfs:comment>
        <rdfs:label>Conservation Results Chain Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://schema.org/identifier -->


    <owl:AnnotationProperty rdf:about="http://schema.org/identifier"/>
    


    <!-- http://schema.org/name -->


    <owl:AnnotationProperty rdf:about="http://schema.org/name"/>
    


    <!-- http://schema.org/version -->


    <owl:AnnotationProperty rdf:about="http://schema.org/version"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#altLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#altLabel"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#broadMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broadMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#historyNote -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#historyNote">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/version"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#memberList -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#memberList"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#notation -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#notation">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#note -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#note"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/name"/>
    </owl:AnnotationProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://metadata.un.org/sdg/ontology#SDGCode -->


    <rdfs:Datatype rdf:about="http://metadata.un.org/sdg/ontology#SDGCode">
        <rdfs:label xml:lang="en">Standard SDG code</rdfs:label>
    </rdfs:Datatype>
    


    <!-- http://metadata.un.org/sdg/ontology#SDGCodeCompact -->


    <rdfs:Datatype rdf:about="http://metadata.un.org/sdg/ontology#SDGCodeCompact">
        <rdfs:label xml:lang="en">Standard SDG code in the compact format</rdfs:label>
    </rdfs:Datatype>
    


    <!-- http://metadata.un.org/sdg/ontology#SDGCodePerm -->


    <rdfs:Datatype rdf:about="http://metadata.un.org/sdg/ontology#SDGCodePerm">
        <rdfs:label xml:lang="en">Permanent SDG indicator code</rdfs:label>
    </rdfs:Datatype>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://metadata.un.org/sdg/ontology#hasIndicator -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#hasIndicator">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <owl:inverseOf rdf:resource="http://metadata.un.org/sdg/ontology#isIndicatorOf"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:label xml:lang="en">has indicator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#hasSeries -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#hasSeries">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <owl:inverseOf rdf:resource="http://metadata.un.org/sdg/ontology#isSeriesOf"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Series"/>
        <rdfs:label xml:lang="en">has series</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#hasTarget -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#hasTarget">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <owl:inverseOf rdf:resource="http://metadata.un.org/sdg/ontology#isTargetOf"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Goal"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdfs:label xml:lang="en">has target</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#isIndicatorOf -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#isIndicatorOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdfs:label xml:lang="en">is indicator of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#isSeriesOf -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#isSeriesOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Series"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:label xml:lang="en">is series of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#isTargetOf -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#isTargetOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Goal"/>
        <rdfs:label xml:lang="en">is target of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://metadata.un.org/sdg/ontology#tier -->


    <owl:ObjectProperty rdf:about="http://metadata.un.org/sdg/ontology#tier">
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:range rdf:resource="http://metadata.un.org/sdg/ontology#Tier"/>
        <rdfs:label xml:lang="en">tier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/dc/terms/subject -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/subject">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/keywords -->


    <owl:ObjectProperty rdf:about="http://schema.org/keywords">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.org/dc/terms/subject"/>
            <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        </owl:propertyChainAxiom>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrower"/>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#addresses -->


    <owl:ObjectProperty rdf:about="https://eriktuck.github.io/results-chain-ontology#addresses">
        <rdfs:domain rdf:resource="https://eriktuck.github.io/results-chain-ontology#Strategy"/>
        <rdfs:range rdf:resource="https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult"/>
        <rdfs:comment>Links a strategy directly to the threat it intends to mitigate.</rdfs:comment>
        <rdfs:label>addresses</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#hasIndicator -->


    <owl:ObjectProperty rdf:about="https://eriktuck.github.io/results-chain-ontology#hasIndicator">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Impact"/>
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Result"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://eriktuck.github.io/results-chain-ontology#Indicator"/>
        <rdfs:comment>Links a result or impact to a specific measurable indicator.</rdfs:comment>
        <rdfs:label>has indicator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#leadsTo -->


    <owl:ObjectProperty rdf:about="https://eriktuck.github.io/results-chain-ontology#leadsTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Result"/>
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Impact"/>
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Result"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>The causal or logical link between a strategy and a result, or between results.</rdfs:comment>
        <rdfs:label>leads to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#occursIn -->


    <owl:ObjectProperty rdf:about="https://eriktuck.github.io/results-chain-ontology#occursIn">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Impact"/>
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Result"/>
                    <rdf:Description rdf:about="https://eriktuck.github.io/results-chain-ontology#Strategy"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://eriktuck.github.io/results-chain-ontology#Context"/>
        <rdfs:comment>Links a component of the results chain to a specific geographic or institutional context.</rdfs:comment>
        <rdfs:label>occurs in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://metadata.un.org/sdg/ontology#custodianAgency -->


    <owl:DatatypeProperty rdf:about="http://metadata.un.org/sdg/ontology#custodianAgency">
        <rdfs:domain rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">has custodian agency</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/keywords -->


    <owl:DatatypeProperty rdf:about="http://schema.org/keywords"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://metadata.un.org/sdg/ontology#Goal -->


    <owl:Class rdf:about="http://metadata.un.org/sdg/ontology#Goal">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">Goal</rdfs:label>
        <rdfs:label xml:lang="fr">Objectif</rdfs:label>
        <rdfs:label xml:lang="es">Objetivo</rdfs:label>
    </owl:Class>
    


    <!-- http://metadata.un.org/sdg/ontology#Indicator -->


    <owl:Class rdf:about="http://metadata.un.org/sdg/ontology#Indicator">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="es">Indicador</rdfs:label>
        <rdfs:label xml:lang="fr">Indicateur</rdfs:label>
        <rdfs:label xml:lang="en">Indicator</rdfs:label>
    </owl:Class>
    


    <!-- http://metadata.un.org/sdg/ontology#Series -->


    <owl:Class rdf:about="http://metadata.un.org/sdg/ontology#Series">
        <rdfs:subClassOf rdf:resource="http://schema.org/Dataset"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="en">Series</rdfs:label>
    </owl:Class>
    


    <!-- http://metadata.un.org/sdg/ontology#Target -->


    <owl:Class rdf:about="http://metadata.un.org/sdg/ontology#Target">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="fr">Cible</rdfs:label>
        <rdfs:label xml:lang="es">Meta</rdfs:label>
        <rdfs:label xml:lang="en">Target</rdfs:label>
    </owl:Class>
    


    <!-- http://metadata.un.org/sdg/ontology#Tier -->


    <owl:Class rdf:about="http://metadata.un.org/sdg/ontology#Tier">
        <rdfs:label xml:lang="en">Tier Classification for Global SDG Indicators</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/Dataset -->


    <owl:Class rdf:about="http://schema.org/Dataset"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#OrderedCollection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#OrderedCollection"/>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#Context -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#Context">
        <rdfs:comment>The external environment, including geographic locations and institutional entities. Populate via Wikifiers (Wikidata/DBpedia).</rdfs:comment>
        <rdfs:label>Context</rdfs:label>
        <skos:note>Align with Wikidata/DBpedia URIs via owl:sameAs</skos:note>
    </owl:Class>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#Impact -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#Impact">
        <rdfs:comment>The desired future state of a conservation target (e.g., species, habitat). Map to ENVO.</rdfs:comment>
        <rdfs:label>Impact</rdfs:label>
        <skos:note>Align with ENVO via skos:narrowMatch</skos:note>
    </owl:Class>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#Indicator -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#Indicator">
        <rdfs:comment>The specific variable used to measure progress toward a result or impact. Map to UNBIS.</rdfs:comment>
        <rdfs:label>Indicator</rdfs:label>
        <skos:note>Align with UNBIS Thesaurus via skos:related</skos:note>
    </owl:Class>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#Result -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#Result">
        <rdfs:comment>A generic term used to describe the desired future state of a factor. Includes intermediate outcomes.</rdfs:comment>
        <rdfs:label>Result</rdfs:label>
    </owl:Class>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#Strategy -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#Strategy">
        <rdfs:comment>The set of actions or interventions that a project implements. Map to CMP Actions or Conservation Evidence Actions.</rdfs:comment>
        <rdfs:label>Strategy</rdfs:label>
        <skos:note>Align with CMP Action Taxonomy via skos:exactMatch</skos:note>
    </owl:Class>
    


    <!-- https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult -->


    <owl:Class rdf:about="https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult">
        <rdfs:subClassOf rdf:resource="https://eriktuck.github.io/results-chain-ontology#Result"/>
        <rdfs:comment>A specific result where a direct threat is diminished. Map to CMP Threats.</rdfs:comment>
        <rdfs:label>Threat Reduction Result</rdfs:label>
        <skos:note>Align with CMP Threat Taxonomy via skos:related</skos:note>
    </owl:Class>
    


