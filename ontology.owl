        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#3"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#7"/>
        <skos:prefLabel xml:lang="en">Install rope or pole (canopy) bridges</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1458 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1458">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Implement speed limits in particular areas (e.g. with high primate densities) to reduce vehicle collisions with primates</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1459 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1459">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Reduce road widths</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/146 -->


