        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.6</skos:notation>
        <skos:note xml:lang="fr">Cible 3.6</skos:note>
        <skos:note xml:lang="es">Meta 3.6</skos:note>
        <skos:note xml:lang="en">Target 3.6</skos:note>
        <skos:prefLabel xml:lang="en">By 2020, halve the number of global deaths and injuries from road traffic accidents</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2020, reducir a la mitad el número de muertes y lesiones causadas por accidentes de tráfico en el mundo</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2020, diminuer de moitié à l’échelle mondiale le nombre de décès et de blessures dus à des accidents de la route</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.7 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.7">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
