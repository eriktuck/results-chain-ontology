        <skos:note xml:lang="fr">Cible 16.5</skos:note>
        <skos:note xml:lang="es">Meta 16.5</skos:note>
        <skos:note xml:lang="en">Target 16.5</skos:note>
        <skos:prefLabel xml:lang="es">Reducir considerablemente la corrupción y el soborno en todas sus formas</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Réduire nettement la corruption et la pratique des pots-de-vin sous toutes leurs formes</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Substantially reduce corruption and bribery in all their forms</skos:prefLabel>
    </owl:NamedIndividual>
    


