        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Install speed bumps to reduce vehicle collisions with primates</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1466 -->


