        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">07.01</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">7.1</skos:notation>
        <skos:note xml:lang="fr">Cible 7.1</skos:note>
        <skos:note xml:lang="es">Meta 7.1</skos:note>
        <skos:note xml:lang="en">Target 7.1</skos:note>
        <skos:prefLabel xml:lang="en">By 2030, ensure universal access to affordable, reliable and modern energy services</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2030, garantizar el acceso universal a servicios energéticos asequibles, fiables y modernos</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2030, garantir l’accès de tous à des services énergétiques fiables et modernes, à un coût abordable</skos:prefLabel>
    </owl:NamedIndividual>
    


