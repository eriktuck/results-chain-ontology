        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.1"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.2"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.3"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.4"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.5"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.6"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/4.7"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/512"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/668"/>
