        <skos:prefLabel xml:lang="es">Proporción de jóvenes y adultos con competencias en tecnología de la información y las comunicaciones (TIC), desglosada por tipo de competencia técnica</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Proportion de jeunes et d’adultes ayant des compétences en informatique et en communication, par type de compétence</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Proportion of youth and adults with information and communications technology (ICT) skills, by type of skill</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/C040501 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/C040501">
