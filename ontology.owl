    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1460 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1460">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Impose fines for breaking the speed limit or colliding with primates</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1461 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1461">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Avoid building roads in key habitat or migration routes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1462 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1462">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Implement a minimum number of roads (&amp; minimize secondary roads) needed to reach mining extraction sites</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1463 -->


