        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.b"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.c"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.1"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.2"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.3"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.4"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.5"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.6"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/10.7"/>
