        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.3</skos:notation>
        <skos:note xml:lang="fr">Cible 16.3</skos:note>
        <skos:note xml:lang="es">Meta 16.3</skos:note>
        <skos:note xml:lang="en">Target 16.3</skos:note>
        <skos:prefLabel xml:lang="en">Promote the rule of law at the national and international levels and ensure equal access to justice for all</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Promouvoir l’état de droit dans l’ordre interne et international et garantir à tous un égal accès à la justice</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Promover el estado de derecho en los planos nacional e internacional y garantizar la igualdad de acceso a la justicia para todos</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.4 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.4">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
