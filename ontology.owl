        <terms:subject rdf:resource="http://eurovoc.europa.eu/339"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/416"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/5463"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/030600"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1001550"/>
