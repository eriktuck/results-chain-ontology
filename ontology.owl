        <ontology:custodianAgency>UN Women</ontology:custodianAgency>
        <ontology:custodianAgency>World Bank</ontology:custodianAgency>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00020065"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">05.01.01</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">5.1.1</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodePerm">C050101</skos:notation>
        <skos:note xml:lang="es">Indicador 5.1.1</skos:note>
        <skos:note xml:lang="fr">Indicateur 5.1.1</skos:note>
        <skos:note xml:lang="en">Indicator 5.1.1</skos:note>
        <skos:prefLabel xml:lang="es">Determinar si existen o no marcos jurídicos para promover, hacer cumplir y supervisar la igualdad y la no discriminación por razón de sexo</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Présence ou absence d’un cadre juridique visant à promouvoir, faire respecter et suivre l’application des principes d’égalité des sexes et de non-discrimination fondée sur le sexe</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Whether or not legal frameworks are in place to promote, enforce and monitor equality and non‑discrimination on the basis of sex</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/C050201 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/C050201">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:isIndicatorOf rdf:resource="http://metadata.un.org/sdg/5.2"/>
        <ontology:tier rdf:resource="http://metadata.un.org/sdg/ontology#tier_II"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/4728"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/6557"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1000066"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1001744"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1002609"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1006882"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1007030"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1007107"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/5.2"/>
        <ontology:custodianAgency>UN Women</ontology:custodianAgency>
        <ontology:custodianAgency>UNFPA</ontology:custodianAgency>
        <ontology:custodianAgency>UNICEF</ontology:custodianAgency>
        <ontology:custodianAgency>UNODC</ontology:custodianAgency>
        <ontology:custodianAgency>WHO</ontology:custodianAgency>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00020066"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">05.02.01</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">5.2.1</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodePerm">C050201</skos:notation>
        <skos:note xml:lang="es">Indicador 5.2.1</skos:note>
        <skos:note xml:lang="fr">Indicateur 5.2.1</skos:note>
        <skos:note xml:lang="en">Indicator 5.2.1</skos:note>
        <skos:prefLabel xml:lang="es">Proporción de mujeres y niñas a partir de 15 años de edad que han sufrido violencia física, sexual o psicológica a manos de su actual o anterior pareja en los últimos 12 meses, desglosada por forma de violencia y edad</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Proportion de femmes et de filles âgées de 15 ans ou plus ayant vécu en couple victimes de violences physiques, sexuelles ou psychologiques infligées au cours des 12 mois précédents par leur partenaire actuel ou un ancien partenaire, par forme de violence et par âge</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Proportion of ever-partnered women and girls aged 15 years and older subjected to physical, sexual or psychological violence by a current or former intimate partner in the previous 12 months, by form of violence and by age</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/C050202 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/C050202">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:isIndicatorOf rdf:resource="http://metadata.un.org/sdg/5.2"/>
        <ontology:tier rdf:resource="http://metadata.un.org/sdg/ontology#tier_II"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/5.2"/>
        <ontology:custodianAgency>UN Women</ontology:custodianAgency>
        <ontology:custodianAgency>UNFPA</ontology:custodianAgency>
        <ontology:custodianAgency>UNICEF</ontology:custodianAgency>
        <ontology:custodianAgency>UNODC</ontology:custodianAgency>
        <ontology:custodianAgency>WHO</ontology:custodianAgency>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00020067"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">05.02.02</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">5.2.2</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodePerm">C050202</skos:notation>
        <skos:note xml:lang="es">Indicador 5.2.2</skos:note>
        <skos:note xml:lang="fr">Indicateur 5.2.2</skos:note>
        <skos:note xml:lang="en">Indicator 5.2.2</skos:note>
        <skos:prefLabel xml:lang="es">Proporción de mujeres y niñas a partir de 15 años de edad que han sufrido violencia sexual a manos de personas que no eran su pareja en los últimos12 meses, desglosada por edad y lugar del hecho</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Proportion de femmes et de filles âgées de 15 ans ou plus victimes de violences sexuelles infligées au cours des 12 mois précédents par une personne autre que leur partenaire intime, par âge et lieu des faits</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Proportion of women and girls aged 15 years and older subjected to sexual violence by persons other than an intimate partner in the previous 12 months, by age and place of occurrence</skos:prefLabel>
    </owl:NamedIndividual>
    


