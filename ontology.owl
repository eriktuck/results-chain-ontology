        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Establish no-mining zones in/near watersheds so as to preserve water levels and water quality</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1453 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1453">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Use &apos;set-aside&apos; areas of natural habitat for primate protection within mining area</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1454 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1454">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Certify mines and market their products as ‘primate friendly’ (e.g. ape-friendly cellular phones)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1455 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1455">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Create/preserve primate habitat on islands before dam construction</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1456 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1456">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Install green bridges (overpasses)</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1457 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1457">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
