        <skos:narrower rdf:resource="http://metadata.un.org/sdg/16.9"/>
        <skos:altLabel xml:lang="en">Peace, justice and strong institutions</skos:altLabel>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000050"/>
        <skos:exactMatch rdf:resource="http://www.wikidata.org/entity/Q53581248"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">16</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16</skos:notation>
        <skos:note xml:lang="en">Goal 16</skos:note>
        <skos:note xml:lang="fr">Objectif 16</skos:note>
        <skos:note xml:lang="es">Objetivo 16</skos:note>
        <skos:prefLabel xml:lang="en">Promote peaceful and inclusive societies for sustainable development, provide access to justice for all and build effective, accountable and inclusive institutions at all levels</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Promouvoir l’avènement de sociétés pacifiques et inclusives aux fins du développement durable, assurer l’accès de tous à la justice et mettre en place, à tous les niveaux, des institutions efficaces, responsables et ouvertes à tous</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Promover sociedades pacíficas e inclusivas para el desarrollo sostenible, facilitar el acceso a la justicia para todos y construir a todos los niveles instituciones eficaces e inclusivas que rindan cuentas</skos:prefLabel>
        <skos:topConceptOf rdf:resource="http://metadata.un.org/sdg"/>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.a -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.a">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C160a01"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/16"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/16"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C160a01"/>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000220"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">16.0a</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.a</skos:notation>
        <skos:note xml:lang="fr">Cible 16.a</skos:note>
        <skos:note xml:lang="es">Meta 16.a</skos:note>
        <skos:note xml:lang="en">Target 16.a</skos:note>
        <skos:prefLabel xml:lang="fr">Appuyer, notamment dans le cadre de la coopération internationale, les institutions nationales chargées de renforcer, à tous les niveaux, les moyens de prévenir la violence et de lutter contre le terrorisme et la criminalité, en particulier dans les pays en développement</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Fortalecer las instituciones nacionales pertinentes, incluso mediante la cooperación internacional, para crear a todos los niveles, particularmente en los países en desarrollo, la capacidad de prevenir la violencia y combatir el terrorismo y la delincuencia</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Strengthen relevant national institutions, including through international cooperation, for building capacity at all levels, in particular in developing countries, to prevent violence and combat terrorism and crime</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.b -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.b">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C200204"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/16"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/16"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C200204"/>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000221"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCode">16.0b</skos:notation>
        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.b</skos:notation>
        <skos:note xml:lang="fr">Cible 16.b</skos:note>
        <skos:note xml:lang="es">Meta 16.b</skos:note>
        <skos:note xml:lang="en">Target 16.b</skos:note>
        <skos:prefLabel xml:lang="en">Promote and enforce non-discriminatory laws and policies for sustainable development</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Promouvoir et appliquer des lois et politiques non discriminatoires pour le développement durable</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Promover y aplicar leyes y políticas no discriminatorias en favor del desarrollo sostenible</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.1 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.1">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
