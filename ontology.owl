        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030301"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030302"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030303"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030304"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030305"/>
