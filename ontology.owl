    <!-- https://conservationstandards.org/library-item/actions-classification#A -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#A">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Actions to directly restore a target or mitigate a stress</skos:definition>
        <skos:notation>A</skos:notation>
        <skos:prefLabel xml:lang="en">TARGET RESTORATION / STRESS REDUCTION ACTIONS</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#ActionScheme -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#ActionScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:label xml:lang="en">CMP Actions Classification v2.0</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#B -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#B">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Actions to reduce direct threats or increase positive behaviors</skos:definition>
        <skos:notation>B</skos:notation>
        <skos:prefLabel xml:lang="en">BEHAVORIAL CHANGE / THREAT REDUCTION ACTIONS</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#C -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#C">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Actions to create the conditions necessary for other conservation efforts to succeed</skos:definition>
        <skos:notation>C</skos:notation>
        <skos:prefLabel xml:lang="en">ENABLING CONDITION ACTIONS</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#OTHER -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#OTHER">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Catch-all category for unclassified actions.</skos:definition>
        <skos:notation>OTHER</skos:notation>
        <skos:prefLabel xml:lang="en">UNCLASSIFIED / OTHER</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#A"/>
        <skos:definition xml:lang="en">Actions directly managing or restoring sites, ecosystems and the wider environment</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>1</skos:notation>
        <skos:prefLabel xml:lang="en">Land / Water Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#1.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#1.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#1"/>
        <skos:definition xml:lang="en">Enhancing viability / mitigating stresses for sites and/or ecosystem targets, especially on a smaller scale</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>1.1</skos:notation>
        <skos:prefLabel xml:lang="en">Site/Area Stewardship</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#1.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#1.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#1"/>
        <skos:definition xml:lang="en">Restoring missing or severely degraded ecosystems and ecosystem functions and processes, especially on a large scale</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>1.2</skos:notation>
        <skos:prefLabel xml:lang="en">Ecosystem &amp; Natural Process (Re)Creation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#10 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#10">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#C"/>
        <skos:definition xml:lang="en">Actions creating the institutions needed to support conservation work</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>10</skos:notation>
        <skos:prefLabel xml:lang="en">Institutional Development</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#10.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#10.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#10"/>
        <skos:definition xml:lang="en">The basic work needed to establish and operate conservation organizations</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>10.1</skos:notation>
        <skos:prefLabel xml:lang="en">Internal Organizational Management &amp; Administration</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#10.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#10.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#10"/>
        <skos:definition xml:lang="en">Creating or providing non-financial support &amp; capacity building for conservation organizations</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>10.2</skos:notation>
        <skos:prefLabel xml:lang="en">External Organizational Development &amp; Support</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#10.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#10.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#10"/>
        <skos:definition xml:lang="en">Forming and facilitating partnerships, alliances, and networks of organizations</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>10.3</skos:notation>
        <skos:prefLabel xml:lang="en">Alliance &amp; Partnership Development</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#10.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#10.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#10"/>
        <skos:definition xml:lang="en">Raising and providing funds for conservation work</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>10.4</skos:notation>
        <skos:prefLabel xml:lang="en">Financing Conservation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#A"/>
        <skos:definition xml:lang="en">Actions directly managing or restoring specific species or taxonomic groups</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>2</skos:notation>
        <skos:prefLabel xml:lang="en">Species Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#2.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#2.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#2"/>
        <skos:definition xml:lang="en">Enhancing viability of / mitigating stresses to specific taxa within their current range</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>2.1</skos:notation>
        <skos:prefLabel xml:lang="en">Species Stewardship</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#2.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#2.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#2"/>
        <skos:definition xml:lang="en">Transferring species or genetic material to places where they formerly occurred or to suitable future habitat or benign introductions of species to an ecosystem</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>2.2</skos:notation>
        <skos:prefLabel xml:lang="en">Species Re-Introduction &amp; Translocation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#2.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#2.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#2"/>
        <skos:definition xml:lang="en">Protecting specific taxa in artificial settings with the aim of ultimately restoring them to their natural settings</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>2.3</skos:notation>
        <skos:prefLabel xml:lang="en">Ex-Situ Conservation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#B"/>
        <skos:definition xml:lang="en">Actions making people aware of key issues and/or feeling desired emotions, leading to behavior change</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>3</skos:notation>
        <skos:prefLabel xml:lang="en">Awareness Raising</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#3.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#3.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#3"/>
        <skos:definition xml:lang="en">Promoting desired awareness and/or emotions and subsequent behavior change by providing information to target audiences through appropriate channels</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>3.1</skos:notation>
        <skos:prefLabel xml:lang="en">Outreach &amp; Communications</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#3.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#3.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#3"/>
        <skos:definition xml:lang="en">Promoting desired awareness and subsequent desired behavior change by conducting protests, naming and shaming, civil disobedience, or sabotage activities</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>3.2</skos:notation>
        <skos:prefLabel xml:lang="en">Protests &amp; Civil Disobedience</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#B"/>
        <skos:definition xml:lang="en">Actions monitoring and enforcing compliance with existing laws and policies at all levels to deter threats or compel conservation action</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>4</skos:notation>
        <skos:prefLabel xml:lang="en">Law Enforcement &amp; Prosecution</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#4.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#4.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#4"/>
        <skos:definition xml:lang="en">Detecting, directly stopping, and/or deterring violations of existing laws and policies</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>4.1</skos:notation>
        <skos:prefLabel xml:lang="en">Detection &amp; Arrest</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#4.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#4.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#4"/>
        <skos:definition xml:lang="en">Ensuring appropriate application of sanctions for violations of existing laws and policies</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>4.2</skos:notation>
        <skos:prefLabel xml:lang="en">Criminal Prosecution &amp; Conviction</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#4.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#4.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#4"/>
        <skos:definition xml:lang="en">Threatening or bringing non-criminal legal action to get individuals, organizations, agencies or firms to change or deter undesired behaviors or compel conservation action</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>4.3</skos:notation>
        <skos:prefLabel xml:lang="en">Non-Criminal Legal Action</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#B"/>
        <skos:definition xml:lang="en">Actions using livelihood, other economic and moral incentives to directly influence attitudes and behaviors</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5</skos:notation>
        <skos:prefLabel xml:lang="en">Livelihood, Economic &amp; Moral Incentives</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:definition xml:lang="en">Developing enterprises that directly depend on the maintenance of natural resources or provide substitute livelihoods as a means of changing attitudes and behaviors</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5.1</skos:notation>
        <skos:prefLabel xml:lang="en">Linked Enterprises &amp; Alternative Livelihoods</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:definition xml:lang="en">Developing, promoting and/or providing more environmentally-friendly products or practices that substitute for environmentally damaging ones</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5.2</skos:notation>
        <skos:prefLabel xml:lang="en">Better Products &amp; Management Practices</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:definition xml:lang="en">Using market mechanisms to change behaviors and attitudes</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5.3</skos:notation>
        <skos:prefLabel xml:lang="en">Market-Based Incentives</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:definition xml:lang="en">Using direct or indirect payments or ascribing economic value to change behaviors and attitudes</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5.4</skos:notation>
        <skos:prefLabel xml:lang="en">Direct Economic Incentives</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#5.5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#5.5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#5"/>
        <skos:definition xml:lang="en">Using intangible and moral values to change behaviors and attitudes</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>5.5</skos:notation>
        <skos:prefLabel xml:lang="en">Non-Monetary Values</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#C"/>
        <skos:definition xml:lang="en">Actions directly protecting sites and/or species</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6</skos:notation>
        <skos:prefLabel xml:lang="en">Conservation Designation &amp; Planning</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:definition xml:lang="en">Legally or formally establishing or expanding public or private parks, reserves, and other protected areas roughly equivalent to IUCN Categories I-IV</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6.1</skos:notation>
        <skos:prefLabel xml:lang="en">Protected Area Designation &amp;/or Acquisition</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:definition xml:lang="en">Legally or formally establishing protection of some specific aspect of the natural resources on public or private lands</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6.2</skos:notation>
        <skos:prefLabel xml:lang="en">Easements &amp; Resource Rights</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:definition xml:lang="en">Designating land/water uses or designating conservation areas outside of IUCN Categories I-IV</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6.3</skos:notation>
        <skos:prefLabel xml:lang="en">Land/Water Use Zoning &amp; Designation</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:definition xml:lang="en">Planning for management of sites, species, or thematic conservation projects</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6.4</skos:notation>
        <skos:prefLabel xml:lang="en">Conservation Planning</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#6.5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#6.5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:definition xml:lang="en">Building or maintaining the physical infrastructure for protected areas and other conservation sites</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>6.5</skos:notation>
        <skos:prefLabel xml:lang="en">Site Infrastructure</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#7 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#7">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#C"/>
        <skos:definition xml:lang="en">Actions developing and influencing legislation, policies and voluntary standards affecting conservation</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>7</skos:notation>
        <skos:prefLabel xml:lang="en">Legal &amp; Policy Frameworks</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#7.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#7.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#7"/>
        <skos:definition xml:lang="en">Creating, amending, or influencing laws, regulations and codes at all levels</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>7.1</skos:notation>
        <skos:prefLabel xml:lang="en">Laws, Regulations &amp; Codes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#7.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#7.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#7"/>
        <skos:definition xml:lang="en">Creating, amending, or influencing policies and guidelines at all levels</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>7.2</skos:notation>
        <skos:prefLabel xml:lang="en">Policies &amp; Guidelines</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#8 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#8">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#C"/>
        <skos:definition xml:lang="en">Actions collecting data and transforming it into information to support conservation work</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>8</skos:notation>
        <skos:prefLabel xml:lang="en">Research &amp; Monitoring</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#8.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#8.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#8"/>
        <skos:definition xml:lang="en">Collecting, managing and analyzing data and creating information about any conservation-related factors</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>8.1</skos:notation>
        <skos:prefLabel xml:lang="en">Basic Research &amp; Status Monitoring</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#8.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#8.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#8"/>
        <skos:definition xml:lang="en">Assessing and learning about the effectiveness of conservation work</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>8.2</skos:notation>
        <skos:prefLabel xml:lang="en">Evaluation, Effectiveness Measures &amp; Learning</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#9 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#9">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#C"/>
        <skos:definition xml:lang="en">Actions enhancing the knowledge and skills of specific individuals</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>9</skos:notation>
        <skos:prefLabel xml:lang="en">Education &amp; Training</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#9.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#9.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#9"/>
        <skos:definition xml:lang="en">Enhancing knowledge and skills of students in a formal degree program</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>9.1</skos:notation>
        <skos:prefLabel xml:lang="en">Formal Education</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/actions-classification#9.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/actions-classification#9.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/actions-classification#9"/>
        <skos:definition xml:lang="en">Enhancing knowledge, skills and information exchange for practitioners, stakeholders, and other relevant individuals in structured settings outside of degree programs</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/actions-classification#ActionScheme"/>
        <skos:notation>9.2</skos:notation>
        <skos:prefLabel xml:lang="en">Training &amp; Individual Capacity Development</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#A -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#A">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Human uses of land and water areas that have a substantial spatial footprint. Includes effects from their construction (e.g. ecosystem conversion), ongoing use, and abandonment.</skos:definition>
        <skos:notation>A</skos:notation>
        <skos:prefLabel xml:lang="en">Use of Lands &amp; Waters</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#B -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#B">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Human uses of biotic resources and disturbance from human presence or management actions in natural systems.</skos:definition>
        <skos:notation>B</skos:notation>
        <skos:prefLabel xml:lang="en">Use / Management of Species &amp; Ecosystems</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#C -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#C">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Stressors in natural systems that have been altered by the effects of current or historical human actions.</skos:definition>
        <skos:notation>C</skos:notation>
        <skos:prefLabel xml:lang="en">Additional Sources of Stress</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#OTHER -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#OTHER">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">Catch-all category for unclassified threats.</skos:definition>
        <skos:notation>OTHER</skos:notation>
        <skos:prefLabel xml:lang="en">UNCLASSIFIED / OTHER</skos:prefLabel>
        <skos:topConceptOf rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#ThreatScheme -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:label xml:lang="en">CMP Direct Threats Classification v4.0</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#A"/>
        <skos:definition xml:lang="en">Human settlements, industrial areas, and other non-agricultural land uses with a substantial footprint.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>1</skos:notation>
        <skos:prefLabel xml:lang="en">Residential, Commercial &amp; Recreation Areas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#1.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#1.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#1"/>
        <skos:definition xml:lang="en">Cities, towns, and settlements including non-housing development typically integrated with housing.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>1.1</skos:notation>
        <skos:prefLabel xml:lang="en">Residential Areas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#1.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#1.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#1"/>
        <skos:definition xml:lang="en">Factories and other commercial centers.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>1.2</skos:notation>
        <skos:prefLabel xml:lang="en">Commercial &amp; Industrial Areas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#1.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#1.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#1"/>
        <skos:definition xml:lang="en">Tourism and recreation sites with a substantial spatial footprint that are not fully integrated into municipal areas.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>1.3</skos:notation>
        <skos:prefLabel xml:lang="en">Recreation &amp; Tourism Areas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#10 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#10">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#C"/>
        <skos:definition xml:lang="en">Potentially catastrophic natural disturbances that conservation practitioners may still need to consider, particularly when managing small and/or remnant species populations or ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>10</skos:notation>
        <skos:prefLabel xml:lang="en">Natural Disasters</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#10.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#10.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#10"/>
        <skos:definition xml:lang="en">Specific geological events that have potentially catastrophic effects on vulnerable species and ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>10.1</skos:notation>
        <skos:prefLabel xml:lang="en">Geological Events</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#10.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#10.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#10"/>
        <skos:definition xml:lang="en">Specific weather events that have potentially catastrophic effects on vulnerable species and ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>10.2</skos:notation>
        <skos:prefLabel xml:lang="en">Severe Weather Events</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#11 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#11">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#C"/>
        <skos:definition xml:lang="en">Change in climate patterns resulting from increased atmospheric greenhouse gasses.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>11</skos:notation>
        <skos:prefLabel xml:lang="en">Climate Change</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#11.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#11.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#11"/>
        <skos:definition xml:lang="en">Broad-scale changes in the abiotic conditions of ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>11.1</skos:notation>
        <skos:prefLabel xml:lang="en">Changes in Physical &amp; Chemical Regimes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#11.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#11.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#11"/>
        <skos:definition xml:lang="en">Broad-scale changes in temperature mean, variability, seasonality and extremes, including changes in temperature extremes, increased average summer temperature, and decreased minimum winter/spring temperature.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>11.2</skos:notation>
        <skos:prefLabel xml:lang="en">Changes in Temperature Regimes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#11.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#11.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#11"/>
        <skos:definition xml:lang="en">Broad-scale changes in precipitation mean, variability, seasonality, and extremes, including decreased or increased precipitation, changes in timing of precipitation, changes in form of precipitation (eg snow vs rain), changes in evapotranspiration rates and hydrological cycles, and droughts and floods.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>11.3</skos:notation>
        <skos:prefLabel xml:lang="en">Changes in Precipitation &amp; Hydrological Regimes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#12 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#12">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#C"/>
        <skos:definition xml:lang="en">Threats that cannot be identified.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>12</skos:notation>
        <skos:prefLabel xml:lang="en">Unknown Threats</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#A"/>
        <skos:definition xml:lang="en">Farming and ranching including agricultural expansion, intensification, or practices with a spatial footprint; includes tree plantations, mariculture, and aquaculture.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>2</skos:notation>
        <skos:prefLabel xml:lang="en">Agriculture &amp; Aquaculture</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#2.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#2.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#2"/>
        <skos:definition xml:lang="en">Crops planted for food, fodder, fiber, fuel, or other uses.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>2.1</skos:notation>
        <skos:prefLabel xml:lang="en">Annual &amp; Perennial Non-Timber Crops</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#2.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#2.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#2"/>
        <skos:definition xml:lang="en">Stands of trees planted for timber or fiber outside of natural forests, often with non-native species.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>2.2</skos:notation>
        <skos:prefLabel xml:lang="en">Wood &amp; Pulp Plantations</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#2.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#2.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#2"/>
        <skos:definition xml:lang="en">Domestic terrestrial animals raised in one location on farmed or non-local resources (farming); also domestic or semidomesticated animals allowed to roam in semi-natural areas (ranching) or the wild and supported by natural habitats (herding).</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>2.3</skos:notation>
        <skos:prefLabel xml:lang="en">Terrestrial Animal Farming, Ranching &amp; Herding</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#2.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#2.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#2"/>
        <skos:definition xml:lang="en">Aquatic species raised for harvest in artificial water bodies (analogous to terrestrial &apos;farming&apos;), enclosures in natural waters (analogous to &apos;ranching&apos;), or unenclosed natural waters (analogous to &apos;herding&apos;).</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>2.4</skos:notation>
        <skos:prefLabel xml:lang="en">Marine &amp; Freshwater Aquaculture</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#A"/>
        <skos:definition xml:lang="en">Extraction of non-biological resources, often widely dispersed across the land / sea scape.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>3</skos:notation>
        <skos:prefLabel xml:lang="en">Energy Production &amp; Mining</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#3.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#3.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#3"/>
        <skos:definition xml:lang="en">Exploring for and extracting petroleum and other liquid hydrocarbons.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>3.1</skos:notation>
        <skos:prefLabel xml:lang="en">Oil &amp; Gas Exploration &amp; Extraction</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#3.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#3.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#3"/>
        <skos:definition xml:lang="en">Exploring for and developing and producing minerals and rocks.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>3.2</skos:notation>
        <skos:prefLabel xml:lang="en">Mining &amp; Quarrying</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#3.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#3.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#3"/>
        <skos:definition xml:lang="en">Exploring for and developing and producing renewable energy.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>3.3</skos:notation>
        <skos:prefLabel xml:lang="en">Renewable Energy</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#A"/>
        <skos:definition xml:lang="en">Linear infrastructure such as long, narrow service or transport corridors including the effects associated with their use (e.g. mortality from vehicle collisions, restriction of species movement).</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4</skos:notation>
        <skos:prefLabel xml:lang="en">Transportation, Service &amp; Security Corridors</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#4"/>
        <skos:definition xml:lang="en">Transport on roadways and dedicated tracks.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4.1</skos:notation>
        <skos:prefLabel xml:lang="en">Roads, Trails &amp; Railroads</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#4"/>
        <skos:definition xml:lang="en">Transport of energy &amp; resources.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4.2</skos:notation>
        <skos:prefLabel xml:lang="en">Utility &amp; Service Lines</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#4"/>
        <skos:definition xml:lang="en">Transport on and in freshwater and ocean waterways.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4.3</skos:notation>
        <skos:prefLabel xml:lang="en">Shipping Lanes</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#4"/>
        <skos:definition xml:lang="en">Air and space transport and other activities.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4.4</skos:notation>
        <skos:prefLabel xml:lang="en">Atmospheric &amp; Space Activities</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#4.5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#4.5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#4"/>
        <skos:definition xml:lang="en">Barriers to movement.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>4.5</skos:notation>
        <skos:prefLabel xml:lang="en">Fencing &amp; Walls</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#B"/>
        <skos:definition xml:lang="en">Consumptive use of &quot;wild&quot; biological resources including deliberate and unintentional harvesting effects as well as persecution of specific species.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>5</skos:notation>
        <skos:prefLabel xml:lang="en">Biological Resource Use &amp; Control</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#5.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#5.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#5"/>
        <skos:definition xml:lang="en">Hunting or trapping terrestrial wild animals for commercial, recreation, subsistence, research, or cultural purposes, or killing them for persecution or control reasons; includes non-lethal animal product harvesting and accidental mortality/bycatch.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>5.1</skos:notation>
        <skos:prefLabel xml:lang="en">Hunting, Collecting &amp; Controlling Terrestrial Animals</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#5.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#5.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#5"/>
        <skos:definition xml:lang="en">Harvesting plants, fungi, and other non-timber/non-animal products for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>5.2</skos:notation>
        <skos:prefLabel xml:lang="en">Gathering, Harvesting &amp; Controlling Terrestrial Plants &amp; Fungi</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#5.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#5.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#5"/>
        <skos:definition xml:lang="en">Harvesting trees and other woody vegetation for timber, fiber, or fuel, including site preparation and other forestry management practices; includes non-lethal coppicing and accidental mortality/bycatch.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>5.3</skos:notation>
        <skos:prefLabel xml:lang="en">Logging, Harvesting &amp; Controlling Trees</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#5.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#5.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#5"/>
        <skos:definition xml:lang="en">Harvesting aquatic wild animals or plants for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>5.4</skos:notation>
        <skos:prefLabel xml:lang="en">Fishing, Harvesting &amp; Controlling Aquatic Species</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#6 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#6">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#B"/>
        <skos:definition xml:lang="en">Human activities that alter, disturb, and destroy ecosystems and species associated with non-consumptive uses of biological areas and resources.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>6</skos:notation>
        <skos:prefLabel xml:lang="en">Human Intrusions &amp; Disturbances</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#6.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#6.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#6"/>
        <skos:definition xml:lang="en">People spending time in natural areas or traveling in vehicles outside of established transport corridors, usually for recreational reasons.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>6.1</skos:notation>
        <skos:prefLabel xml:lang="en">Recreational Activities</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#6.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#6.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#6"/>
        <skos:definition xml:lang="en">Actions in natural areas by formal or paramilitary forces without a permanent footprint.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>6.2</skos:notation>
        <skos:prefLabel xml:lang="en">Conflict, Civil Unrest &amp; Security Activities</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#6.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#6.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#6"/>
        <skos:definition xml:lang="en">People spending time in or traveling in natural environments for reasons other than recreation or conflict/security activities</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>6.3</skos:notation>
        <skos:prefLabel xml:lang="en">Other Human Disturbances</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#B"/>
        <skos:definition xml:lang="en">Human actions that modify ecosystem structures, composition, or regimes, generally to deliberately improve human welfare or benefit certain species. This category includes both construction of permanent or long-term structures and their operations as well as more transitory management practices.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7</skos:notation>
        <skos:prefLabel xml:lang="en">Natural System Management &amp; Modifications</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Management actions that either suppress or increase fire frequency and/or intensity.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.1</skos:notation>
        <skos:prefLabel xml:lang="en">Fire &amp; Fire Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Management actions that modify water levels, flows, and chemistry.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.2</skos:notation>
        <skos:prefLabel xml:lang="en">Dams &amp; Water Management / Use</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Management actions that modify the geophysical environment and/or change sediment regimes.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.3</skos:notation>
        <skos:prefLabel xml:lang="en">Earth &amp; Sediment Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Management actions that modify atmospheric structure and processes.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.4</skos:notation>
        <skos:prefLabel xml:lang="en">Weather &amp; Climate Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.5 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.5">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Management actions that modify biotic systems including conservation actions that may have detrimental impacts on other non-targeted species or ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.5</skos:notation>
        <skos:prefLabel xml:lang="en">Biological System Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#7.6 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#7.6">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#7"/>
        <skos:definition xml:lang="en">Absence or reduction of current or historical management regimes important for maintaining desired key ecological attributes of ecosystems or species. Includes regimes historically maintained by protected area staff, farmers and ranchers, indigenous peoples, private landowners, or any other resource manager.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>7.6</skos:notation>
        <skos:prefLabel xml:lang="en">Removing / Reducing Human Management</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#8 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#8">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#C"/>
        <skos:definition xml:lang="en">Threats from non-native and native plants, animals, pathogens/microbes, or genetic materials that have or are predicted to have harmful effects on biodiversity following their introduction, spread and/or increase in abundance or virulence.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>8</skos:notation>
        <skos:prefLabel xml:lang="en">Invasive / Other Problematic Species, Genes &amp; Pathogens</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#8.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#8.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#8"/>
        <skos:definition xml:lang="en">Harmful plants, animals, and other species not originally found within the ecosystem(s) in question and directly or indirectly introduced and spread into it by human activities.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>8.1</skos:notation>
        <skos:prefLabel xml:lang="en">Invasive Non-Native / Alien Species</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#8.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#8.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#8"/>
        <skos:definition xml:lang="en">Harmful plants, animals, and other species that are originally found within the ecosystem(s) in question, but have become “out-of-balance” or “released” directly or indirectly due to human activities.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>8.2</skos:notation>
        <skos:prefLabel xml:lang="en">Problematic Native Species</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#8.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#8.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#8"/>
        <skos:definition xml:lang="en">Human caused introduction of natural or synthetic genes into species in natural ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>8.3</skos:notation>
        <skos:prefLabel xml:lang="en">Introduced Genetic Material</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#8.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#8.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#8"/>
        <skos:definition xml:lang="en">Harmful native and non-native agents that cause disease or illness to a host species, including bacteria, viruses, prions, fungi, and other microorganisms.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>8.4</skos:notation>
        <skos:prefLabel xml:lang="en">Pathogens</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#9 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#9">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#C"/>
        <skos:definition xml:lang="en">Introduction of exotic and/or excess materials or energy from point and nonpoint sources.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>9</skos:notation>
        <skos:prefLabel xml:lang="en">Pollution</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#9.1 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#9.1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#9"/>
        <skos:definition xml:lang="en">Water-borne and other liquid pollutants stemming from various human activities; includes both the effects of these pollutants on the sites where they are generated/applied and where they end up in the environment.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>9.1</skos:notation>
        <skos:prefLabel xml:lang="en">Water-Borne &amp; Other Effluent Pollution</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#9.2 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#9.2">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#9"/>
        <skos:definition xml:lang="en">Rubbish and other solid materials including those that entangle wildlife.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>9.2</skos:notation>
        <skos:prefLabel xml:lang="en">Garbage &amp; Solid Waste</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#9.3 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#9.3">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#9"/>
        <skos:definition xml:lang="en">Atmospheric pollutants from point and nonpoint sources.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>9.3</skos:notation>
        <skos:prefLabel xml:lang="en">Air-Borne Pollutants</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://conservationstandards.org/library-item/threats-classification/#9.4 -->


    <owl:NamedIndividual rdf:about="https://conservationstandards.org/library-item/threats-classification/#9.4">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://conservationstandards.org/library-item/threats-classification/#9"/>
        <skos:definition xml:lang="en">Inputs of heat, sound, light, or other wave energy that disturb species or ecosystems.</skos:definition>
        <skos:inScheme rdf:resource="https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"/>
        <skos:notation>9.4</skos:notation>
        <skos:prefLabel xml:lang="en">Energy Emissions</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/Scheme -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/Scheme">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:label xml:lang="en">Conservation Evidence Actions Taxonomy</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BeeConservation"/>
        <skos:prefLabel xml:lang="en">Plant parks and gardens with appropriate flowers</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/10 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/10">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BeeConservation"/>
        <skos:prefLabel xml:lang="en">Connect areas of natural or semi-natural habitat for bees</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/100 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/100">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/FarmlandConservation"/>
        <skos:prefLabel xml:lang="en">Avoid use of lead shot</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1000 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1000">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Educate the public to improve perception of bats to improve behaviour towards bats</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1001 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1001">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Restore and maintain microclimate in modified caves</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1002 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1002">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#1"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#6"/>
        <skos:prefLabel xml:lang="en">Impose restrictions on cave visits</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1003 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1003">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Inform the public of ways to reduce disturbance to bats in caves</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1005 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1005">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Provide artificial subterranean bat roosts to replace roosts in disturbed caves</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1006 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1006">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#1"/>
        <skos:prefLabel xml:lang="en">Use prescribed burning</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1007 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1007">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#1"/>
        <skos:prefLabel xml:lang="en">Control invasive predators</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1008 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1008">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Control invasive plant species</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1009 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1009">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/BatConservation"/>
        <skos:prefLabel xml:lang="en">Translocate bats</skos:prefLabel>
