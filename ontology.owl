        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030304"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030305"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/3"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1001123"/>
        <terms:subject rdf:resource="http://metadata.un.org/thesaurus/1001705"/>
