        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.3</skos:notation>
        <skos:note xml:lang="fr">Cible 3.3</skos:note>
        <skos:note xml:lang="es">Meta 3.3</skos:note>
        <skos:note xml:lang="en">Target 3.3</skos:note>
        <skos:prefLabel xml:lang="en">By 2030, end the epidemics of AIDS, tuberculosis, malaria and neglected tropical diseases and combat hepatitis, water-borne diseases and other communicable diseases</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2030, poner fin a las epidemias del SIDA, la tuberculosis, la malaria y las enfermedades tropicales desatendidas y combatir la hepatitis, las enfermedades transmitidas por el agua y otras enfermedades transmisibles</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2030, mettre fin à l’épidémie de sida, à la tuberculose, au paludisme et aux maladies tropicales négligées et combattre l’hépatite, les maladies transmises par l’eau et autres maladies transmissibles</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.4 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.4">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030401"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030402"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/3"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/1991"/>
        <terms:subject rdf:resource="http://eurovoc.europa.eu/5291"/>
