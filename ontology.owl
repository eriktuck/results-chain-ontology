        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">3.4</skos:notation>
        <skos:note xml:lang="fr">Cible 3.4</skos:note>
        <skos:note xml:lang="es">Meta 3.4</skos:note>
        <skos:note xml:lang="en">Target 3.4</skos:note>
        <skos:prefLabel xml:lang="en">By 2030, reduce by one third premature mortality from non-communicable diseases through prevention and treatment and promote mental health and well-being</skos:prefLabel>
        <skos:prefLabel xml:lang="es">De aquí a 2030, reducir en un tercio la mortalidad prematura por enfermedades no transmisibles mediante su prevención y tratamiento, y promover la salud mental y el bienestar</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">D’ici à 2030, réduire d’un tiers, par la prévention et le traitement, le taux de mortalité prématurée due à des maladies non transmissibles et promouvoir la santé mentale et le bien-être</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/3.5 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/3.5">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030501"/>
        <ontology:hasIndicator rdf:resource="http://metadata.un.org/sdg/C030502"/>
        <ontology:isTargetOf rdf:resource="http://metadata.un.org/sdg/3"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/3"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030501"/>
        <skos:narrower rdf:resource="http://metadata.un.org/sdg/C030502"/>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00000090"/>
        <skos:inScheme rdf:resource="http://metadata.un.org/sdg"/>
