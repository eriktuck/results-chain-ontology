        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.2</skos:notation>
        <skos:note xml:lang="fr">Cible 16.2</skos:note>
        <skos:note xml:lang="es">Meta 16.2</skos:note>
        <skos:note xml:lang="en">Target 16.2</skos:note>
        <skos:prefLabel xml:lang="en">End abuse, exploitation, trafficking and all forms of violence against and torture of children</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Mettre un terme à la maltraitance, à l’exploitation et à la traite, et à toutes les formes de violence et de torture dont sont victimes les enfants</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Poner fin al maltrato, la explotación, la trata y todas las formas de violencia y tortura contra los niños</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.3 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.3">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
