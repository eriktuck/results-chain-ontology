        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/9.2"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/9.3"/>
        <ontology:hasTarget rdf:resource="http://metadata.un.org/sdg/9.4"/>
