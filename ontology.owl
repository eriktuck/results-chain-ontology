        <skos:notation rdf:datatype="http://metadata.un.org/sdg/ontology#SDGCodeCompact">16.10</skos:notation>
        <skos:note xml:lang="fr">Cible 16.10</skos:note>
        <skos:note xml:lang="es">Meta 16.10</skos:note>
        <skos:note xml:lang="en">Target 16.10</skos:note>
        <skos:prefLabel xml:lang="en">Ensure public access to information and protect fundamental freedoms, in accordance with national legislation and international agreements</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Garantir l’accès public à l’information et protéger les libertés fondamentales, conformément à la législation nationale et aux accords internationaux</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Garantizar el acceso público a la información y proteger las libertades fundamentales, de conformidad con las leyes nacionales y los acuerdos internacionales</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://metadata.un.org/sdg/16.2 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/16.2">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Target"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
