        <skos:prefLabel xml:lang="es">Crear a todos los niveles instituciones eficaces y transparentes que rindan cuentas</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Develop effective, accountable and transparent institutions at all levels</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Mettre en place des institutions efficaces, responsables et transparentes à tous les niveaux</skos:prefLabel>
    </owl:NamedIndividual>
    


