        <skos:broadMatch rdf:resource="https://conservationstandards.org/library-item/actions-classification#7"/>
        <skos:prefLabel xml:lang="en">Avoid/minimize logging of important food tree species for primates</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1495 -->


    <owl:NamedIndividual rdf:about="https://www.conservationevidence.com/actions/1495">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="https://www.conservationevidence.com/synopsis/PrimateConservation"/>
        <skos:prefLabel xml:lang="en">Incorporate forested corridors or buffers into logged areas</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- https://www.conservationevidence.com/actions/1496 -->


