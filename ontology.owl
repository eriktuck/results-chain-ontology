    <!-- http://metadata.un.org/sdg/C120801 -->


    <owl:NamedIndividual rdf:about="http://metadata.un.org/sdg/C120801">
        <rdf:type rdf:resource="http://metadata.un.org/sdg/ontology#Indicator"/>
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <ontology:isIndicatorOf rdf:resource="http://metadata.un.org/sdg/12.8"/>
        <ontology:tier rdf:resource="http://metadata.un.org/sdg/ontology#tier_III"/>
        <skos:broader rdf:resource="http://metadata.un.org/sdg/12.8"/>
        <ontology:custodianAgency>UNESCO-UIS</ontology:custodianAgency>
        <skos:exactMatch rdf:resource="http://purl.unep.org/sdg/SDGIO_00020155"/>
