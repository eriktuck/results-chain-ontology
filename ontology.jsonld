  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Nombre de pays ayant fait état du renforcement de leurs capacités institutionnelles, systémiques et individuelles pour favoriser les mesures d’adaptation et d’atténuation, le transfert de technologie et les activités en faveur du développement"
  }, {
    "@language" : "en",
    "@value" : "Number of countries that have communicated the strengthening of institutional, systemic and individual capacity-building to implement adaptation, mitigation and technology transfer, and development actions"
  }, {
    "@language" : "es",
    "@value" : "Número de países que han comunicado una mayor creación de capacidad institucional, sistémica e individual para implementar actividades de adaptación, mitigación y transferencia de tecnología, y medidas de desarrollo"
  } ]
