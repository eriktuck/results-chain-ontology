    "@value" : "04"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "4"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 4"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 4"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Assurer à tous une éducation équitable, inclusive et de qualité et des possibilités d’apprentissage    tout au long de la vie"
  }, {
    "@language" : "en",
    "@value" : "Ensure inclusive and equitable quality education and promote lifelong learning opportunities for all"
  }, {
    "@language" : "es",
    "@value" : "Garantizar una educación inclusiva y equitativa de calidad y promover oportunidades de aprendizaje permanente para todos"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/4.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C040101"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
