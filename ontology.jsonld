  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 10"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 10"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 10"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Reduce inequality within and among countries"
  }, {
    "@language" : "es",
    "@value" : "Reducir la desigualdad en los países y entre ellos"
  }, {
    "@language" : "fr",
    "@value" : "Réduire les inégalités dans les pays et d’un pays à l’autre"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C100101"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
