  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/ontology#tier_I",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Tier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicator is conceptually clear, has an internationally established methodology and standards are available, and data are regularly produced by countries for at least 50 per cent of countries and of the population in every region where the indicator is relevant."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tier I"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/ontology#tier_II",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Tier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Indicator is conceptually clear, has an internationally established methodology and standards are available, but data are not regularly produced by countries."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tier II"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/ontology#tier_III",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Tier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "No internationally established methodology or standards are yet available for the indicator, but methodology/standards are being (or will be) developed or tested."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://unstats.un.org/sdgs/iaeg-sdgs/tier-classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Tier III"
  } ]
