  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, double the global rate of improvement in energy efficiency"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, duplicar la tasa mundial de mejora de la eficiencia energética"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, multiplier par deux le taux mondial d’amélioration de l’efficacité énergétique"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/7.a",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C070a01"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
