  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Transport of energy & resources."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
