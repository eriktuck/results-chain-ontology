    "@language" : "en",
    "@value" : "Using intangible and moral values to change behaviors and attitudes"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Non-Monetary Values"
  } ]
