  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "16.0a"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "16.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 16.a"
  }, {
    "@language" : "es",
    "@value" : "Meta 16.a"
  }, {
    "@language" : "en",
    "@value" : "Target 16.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Appuyer, notamment dans le cadre de la coopération internationale, les institutions nationales chargées de renforcer, à tous les niveaux, les moyens de prévenir la violence et de lutter contre le terrorisme et la criminalité, en particulier dans les pays en développement"
  }, {
    "@language" : "es",
    "@value" : "Fortalecer las instituciones nacionales pertinentes, incluso mediante la cooperación internacional, para crear a todos los niveles, particularmente en los países en desarrollo, la capacidad de prevenir la violencia y combatir el terrorismo y la delincuencia"
  }, {
    "@language" : "en",
    "@value" : "Strengthen relevant national institutions, including through international cooperation, for building capacity at all levels, in particular in developing countries, to prevent violence and combat terrorism and crime"
  } ]
