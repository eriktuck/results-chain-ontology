  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "12.08"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "12.8"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 12.8"
  }, {
    "@language" : "es",
    "@value" : "Meta 12.8"
  }, {
    "@language" : "en",
    "@value" : "Target 12.8"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, ensure that people everywhere have the relevant information and awareness for sustainable development and lifestyles in harmony with nature"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, asegurar que las personas de todo el mundo tengan la información y los conocimientos pertinentes para el desarrollo sostenible y los estilos de vida en armonía con la naturaleza"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, faire en sorte que toutes les personnes, partout dans le monde, aient les informations et connaissances nécessaires au développement durable et à un style de vie en harmonie avec la nature"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/12.a",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
