  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 8.a"
  }, {
    "@language" : "es",
    "@value" : "Meta 8.a"
  }, {
    "@language" : "en",
