  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C110101"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "11.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "11.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 11.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 11.1"
  }, {
    "@language" : "en",
    "@value" : "Target 11.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, ensure access for all to adequate, safe and affordable housing and basic services and upgrade slums"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, asegurar el acceso de todas las personas a viviendas y servicios básicos adecuados, seguros y asequibles y mejorar los barrios marginales"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, assurer l’accès de tous à un logement et des services de base adéquats et sûrs, à un coût abordable, et assainir les quartiers de taudis"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/11.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C110201"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/11"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/11"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000162"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C110201"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "11.02"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "11.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 11.2"
  }, {
    "@language" : "es",
    "@value" : "Meta 11.2"
  }, {
    "@language" : "en",
    "@value" : "Target 11.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, provide access to safe, affordable, accessible and sustainable transport systems for all, improving road safety, notably by expanding public transport, with special attention to the needs of those in vulnerable situations, women, children, persons with disabilities and older persons"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, proporcionar acceso a sistemas de transporte seguros, asequibles, accesibles y sostenibles para todos y mejorar la seguridad vial, en particular mediante la ampliación del transporte público, prestando especial atención a las necesidades de las personas en situación de vulnerabilidad, las mujeres, los niños, las personas con discapacidad y las personas de edad"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, assurer l’accès de tous à des systèmes de transport sûrs, accessibles et viables, à un coût abordable, en améliorant la sécurité routière, notamment en développant les transports publics, une attention particulière devant être accordée aux besoins des personnes en situation vulnérable, des femmes, des enfants, des personnes handicapées et des personnes âgées"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/11.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C110301"
  }, {
    "@id" : "http://metadata.un.org/sdg/C110302"
  } ],
