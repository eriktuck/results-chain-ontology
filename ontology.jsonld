  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Proporción de países cuyo ordenamiento jurídico (incluido el derecho consuetudinario) garantiza la igualdad de derechos de la mujer a la propiedad o el control de las tierras"
  }, {
    "@language" : "fr",
    "@value" : "Proportion de pays dotés d’un cadre juridique (y compris le droit coutumier) garantissant aux femmes les mêmes droits que les hommes en matière d’accès à la propriété ou au contrôle des terres"
  }, {
    "@language" : "en",
    "@value" : "Proportion of countries where the legal framework (including customary law) guarantees women’s equal rights to land ownership and/or control"
  } ]
