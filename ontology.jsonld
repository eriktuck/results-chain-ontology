  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "End abuse, exploitation, trafficking and all forms of violence against and torture of children"
  }, {
    "@language" : "fr",
    "@value" : "Mettre un terme à la maltraitance, à l’exploitation et à la traite, et à toutes les formes de violence et de torture dont sont victimes les enfants"
  }, {
    "@language" : "es",
    "@value" : "Poner fin al maltrato, la explotación, la trata y todas las formas de violencia y tortura contra los niños"
  } ]
