  "@id" : "https://conservationstandards.org/library-item/threats-classification/#4.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Transport on and in freshwater and ocean waterways."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Shipping Lanes"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#4.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Air and space transport and other activities."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Atmospheric & Space Activities"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#4.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Barriers to movement."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Fencing & Walls"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#B"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Consumptive use of \"wild\" biological resources including deliberate and unintentional harvesting effects as well as persecution of specific species."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Biological Resource Use & Control"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#5.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#5"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Hunting or trapping terrestrial wild animals for commercial, recreation, subsistence, research, or cultural purposes, or killing them for persecution or control reasons; includes non-lethal animal product harvesting and accidental mortality/bycatch."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Hunting, Collecting & Controlling Terrestrial Animals"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#5.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#5"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harvesting plants, fungi, and other non-timber/non-animal products for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Gathering, Harvesting & Controlling Terrestrial Plants & Fungi"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#5.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#5"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harvesting trees and other woody vegetation for timber, fiber, or fuel, including site preparation and other forestry management practices; includes non-lethal coppicing and accidental mortality/bycatch."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Logging, Harvesting & Controlling Trees"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#5.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#5"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harvesting aquatic wild animals or plants for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "5.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Fishing, Harvesting & Controlling Aquatic Species"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#6",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#B"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Human activities that alter, disturb, and destroy ecosystems and species associated with non-consumptive uses of biological areas and resources."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "6"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Human Intrusions & Disturbances"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#6.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#6"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "People spending time in natural areas or traveling in vehicles outside of established transport corridors, usually for recreational reasons."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "6.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Recreational Activities"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#6.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#6"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Actions in natural areas by formal or paramilitary forces without a permanent footprint."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "6.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Conflict, Civil Unrest & Security Activities"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#6.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#6"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "People spending time in or traveling in natural environments for reasons other than recreation or conflict/security activities"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "6.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Other Human Disturbances"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#B"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Human actions that modify ecosystem structures, composition, or regimes, generally to deliberately improve human welfare or benefit certain species. This category includes both construction of permanent or long-term structures and their operations as well as more transitory management practices."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Natural System Management & Modifications"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Management actions that either suppress or increase fire frequency and/or intensity."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Fire & Fire Management"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Management actions that modify water levels, flows, and chemistry."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Dams & Water Management / Use"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Management actions that modify the geophysical environment and/or change sediment regimes."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Earth & Sediment Management"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Management actions that modify atmospheric structure and processes."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Weather & Climate Management"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Management actions that modify biotic systems including conservation actions that may have detrimental impacts on other non-targeted species or ecosystems."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Biological System Management"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#7.6",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#7"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Absence or reduction of current or historical management regimes important for maintaining desired key ecological attributes of ecosystems or species. Includes regimes historically maintained by protected area staff, farmers and ranchers, indigenous peoples, private landowners, or any other resource manager."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "7.6"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Removing / Reducing Human Management"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#8",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#C"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Threats from non-native and native plants, animals, pathogens/microbes, or genetic materials that have or are predicted to have harmful effects on biodiversity following their introduction, spread and/or increase in abundance or virulence."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "8"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Invasive / Other Problematic Species, Genes & Pathogens"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#8.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#8"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harmful plants, animals, and other species not originally found within the ecosystem(s) in question and directly or indirectly introduced and spread into it by human activities."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "8.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Invasive Non-Native / Alien Species"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#8.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#8"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harmful plants, animals, and other species that are originally found within the ecosystem(s) in question, but have become “out-of-balance” or “released” directly or indirectly due to human activities."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "8.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Problematic Native Species"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#8.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#8"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Human caused introduction of natural or synthetic genes into species in natural ecosystems."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "8.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Introduced Genetic Material"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#8.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#8"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Harmful native and non-native agents that cause disease or illness to a host species, including bacteria, viruses, prions, fungi, and other microorganisms."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "8.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Pathogens"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#9",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#C"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Introduction of exotic and/or excess materials or energy from point and nonpoint sources."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "9"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Pollution"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#9.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#9"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Water-borne and other liquid pollutants stemming from various human activities; includes both the effects of these pollutants on the sites where they are generated/applied and where they end up in the environment."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "9.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Water-Borne & Other Effluent Pollution"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#9.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#9"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Rubbish and other solid materials including those that entangle wildlife."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "9.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Garbage & Solid Waste"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#9.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#9"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Atmospheric pollutants from point and nonpoint sources."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "9.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Air-Borne Pollutants"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#9.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#9"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Inputs of heat, sound, light, or other wave energy that disturb species or ecosystems."
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "9.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Energy Emissions"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#A",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Human uses of land and water areas that have a substantial spatial footprint. Includes effects from their construction (e.g. ecosystem conversion), ongoing use, and abandonment."
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "A"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Use of Lands & Waters"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#B",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Human uses of biotic resources and disturbance from human presence or management actions in natural systems."
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "B"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Use / Management of Species & Ecosystems"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#C",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Stressors in natural systems that have been altered by the effects of current or historical human actions."
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "C"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Additional Sources of Stress"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "https://conservationstandards.org/library-item/threats-classification/#ThreatScheme"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/threats-classification/#OTHER",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
