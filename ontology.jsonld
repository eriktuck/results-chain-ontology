    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#2"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Protecting specific taxa in artificial settings with the aim of ultimately restoring them to their natural settings"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "2.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Ex-Situ Conservation"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#B"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Actions making people aware of key issues and/or feeling desired emotions, leading to behavior change"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Awareness Raising"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#3.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#3"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Promoting desired awareness and/or emotions and subsequent behavior change by providing information to target audiences through appropriate channels"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "3.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Outreach & Communications"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#3.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#3"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Promoting desired awareness and subsequent desired behavior change by conducting protests, naming and shaming, civil disobedience, or sabotage activities"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "3.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Protests & Civil Disobedience"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
