  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Fortalecer la prevención y el tratamiento del abuso de sustancias adictivas, incluido el uso indebido de estupefacientes y el consumo nocivo de alcohol"
  }, {
    "@language" : "fr",
    "@value" : "Renforcer la prévention et le traitement de l’abus de substances psychoactives, notamment de stupéfiants et d’alcool"
  }, {
    "@language" : "en",
    "@value" : "Strengthen the prevention and treatment of substance abuse, including narcotic drug abuse and harmful use of alcohol"
  } ]
