  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The desired future state of a conservation target (e.g., species, habitat). Map to ENVO."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Impact"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@value" : "Align with ENVO via skos:narrowMatch"
  } ]
}, {
