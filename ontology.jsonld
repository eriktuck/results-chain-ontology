  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Ensure availability and sustainable management of water and sanitation for all"
  }, {
    "@language" : "fr",
    "@value" : "Garantir l’accès de tous à des services d’alimentation en eau et d’assainissement gérés de façon durable"
  }, {
    "@language" : "es",
    "@value" : "Garantizar la disponibilidad y la gestión sostenible del agua y el saneamiento para todos"
  } ],
