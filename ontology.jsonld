  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "17.03"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "17.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 17.3"
  }, {
    "@language" : "es",
    "@value" : "Meta 17.3"
  }, {
    "@language" : "en",
    "@value" : "Target 17.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Mobiliser des ressources financières supplémentaires de diverses provenances en faveur des pays en développement"
  }, {
    "@language" : "en",
    "@value" : "Mobilize additional financial resources for developing countries from multiple sources"
  }, {
    "@language" : "es",
    "@value" : "Movilizar recursos financieros adicionales de múltiples fuentes para los países en desarrollo"
  } ]
}, {
