    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "05.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "5.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 5.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 5.1"
  }, {
    "@language" : "en",
    "@value" : "Target 5.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "End all forms of discrimination against all women and girls everywhere"
  }, {
    "@language" : "fr",
    "@value" : "Mettre fin, partout dans le monde, à toutes les formes de discrimination à l’égard des femmes et des filles"
  }, {
    "@language" : "es",
    "@value" : "Poner fin a todas las formas de discriminación contra todas las mujeres y las niñas en todo el mundo"
  } ]
}, {
