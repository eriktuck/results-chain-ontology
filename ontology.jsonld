  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.5"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.5"
  }, {
    "@language" : "en",
    "@value" : "Target 10.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Améliorer la réglementation et la surveillance des institutions et marchés financiers mondiaux et renforcer l’application des règles"
  }, {
    "@language" : "en",
    "@value" : "Improve the regulation and monitoring of global financial markets and institutions and strengthen the implementation of such regulations"
  }, {
    "@language" : "es",
    "@value" : "Mejorar la reglamentación y vigilancia de las instituciones y los mercados financieros mundiales y fortalecer la aplicación de esos reglamentos"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.6",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
