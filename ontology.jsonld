  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "10.07"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "10.7"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.7"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.7"
  }, {
    "@language" : "en",
    "@value" : "Target 10.7"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Facilitar la migración y la movilidad ordenadas, seguras, regulares y responsables de las personas, incluso mediante la aplicación de políticas migratorias planificadas y bien gestionadas"
  }, {
    "@language" : "en",
    "@value" : "Facilitate orderly, safe, regular and responsible migration and mobility of people, including through the implementation of planned and well-managed migration policies"
  }, {
    "@language" : "fr",
    "@value" : "Faciliter la migration et la mobilité de façon ordonnée, sûre, régulière et responsable, notamment par la mise en œuvre de politiques migratoires planifiées et bien gérées"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.a",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
