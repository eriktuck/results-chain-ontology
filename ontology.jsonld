  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Promote and enforce non-discriminatory laws and policies for sustainable development"
  }, {
    "@language" : "fr",
    "@value" : "Promouvoir et appliquer des lois et politiques non discriminatoires pour le développement durable"
  }, {
    "@language" : "es",
    "@value" : "Promover y aplicar leyes y políticas no discriminatorias en favor del desarrollo sostenible"
  } ]
