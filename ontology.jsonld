  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Proporción de la población residente en ciudades que aplican planes de desarrollo urbano y regional que tienen en cuenta las previsiones demográficas y las necesidades de recursos, desglosada por tamaño de ciudad"
  }, {
    "@language" : "fr",
    "@value" : "Proportion d’habitants vivant dans des villes qui mettent en œuvre des plans de développement urbains et régionaux tenant compte des projections démographiques et des ressources nécessaires, selon la taille de la ville"
  }, {
    "@language" : "en",
    "@value" : "Proportion of population living in cities that implement urban and regional development plans integrating population projections and resource needs, by size of city"
  } ]
