  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2020, halve the number of global deaths and injuries from road traffic accidents"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2020, reducir a la mitad el número de muertes y lesiones causadas por accidentes de tráfico en el mundo"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2020, diminuer de moitié à l’échelle mondiale le nombre de décès et de blessures dus à des accidents de la route"
  } ]
}, {
