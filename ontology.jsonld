  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Volume de l’aide publique au développement consacrée aux bourses d’études, par secteur et type de formation"
  }, {
    "@language" : "en",
