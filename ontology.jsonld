    "@value" : "Montant des subventions aux combustibles fossiles par unité de PIB (production et consommation) et en proportion des dépenses nationales totales consacrées à ces combustibles"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/C130201",
