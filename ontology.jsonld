    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "09"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "9"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 9"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 9"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 9"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Build resilient infrastructure, promote inclusive and sustainable industrialization and foster innovation"
  }, {
    "@language" : "fr",
    "@value" : "Bâtir une infrastructure résiliente, promouvoir une industrialisation durable qui profite à tous et encourager l’innovation"
  }, {
    "@language" : "es",
    "@value" : "Construir infraestructuras resilientes, promover la industrialización inclusiva y sostenible y fomentar la innovación"
  } ],
