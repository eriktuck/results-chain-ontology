  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Ensure public access to information and protect fundamental freedoms, in accordance with national legislation and international agreements"
  }, {
    "@language" : "fr",
    "@value" : "Garantir l’accès public à l’information et protéger les libertés fondamentales, conformément à la législation nationale et aux accords internationaux"
