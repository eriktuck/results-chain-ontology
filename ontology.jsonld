  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Goal"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Zero hunger"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000036"
  }, {
    "@id" : "http://www.wikidata.org/entity/Q50215926"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/2.a"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.b"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.c"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.1"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.2"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.3"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.4"
  }, {
    "@id" : "http://metadata.un.org/sdg/2.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 2"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 2"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "End hunger, achieve food security and improved nutrition and promote sustainable agriculture"
  }, {
    "@language" : "es",
    "@value" : "Poner fin al hambre, lograr la seguridad alimentaria y la mejora de la nutrición y promover la agricultura sostenible"
  }, {
    "@language" : "fr",
    "@value" : "Éliminer la faim, assurer la sécurité alimentaire, améliorer la nutrition et promouvoir l’agriculture durable"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020101"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020102"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000078"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020101"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020102"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.1"
  }, {
    "@language" : "en",
    "@value" : "Target 2.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, end hunger and ensure access by all people, in particular the poor and people in vulnerable situations, including infants, to safe, nutritious and sufficient food all year round"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, poner fin al hambre y asegurar el acceso de todas las personas, en particular los pobres y las personas en situaciones de vulnerabilidad, incluidos los niños menores de 1 año, a una alimentación sana, nutritiva y suficiente durante todo el año"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, éliminer la faim et faire en sorte que chacun, en particulier les pauvres et les personnes en situation vulnérable, y compris les nourrissons, ait accès toute l’année à une alimentation saine, nutritive et suffisante"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020201"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020202"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000079"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020201"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020202"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.02"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.2"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.2"
  }, {
    "@language" : "en",
    "@value" : "Target 2.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, end all forms of malnutrition, including achieving, by 2025, the internationally agreed targets on stunting and wasting in children under 5 years of age, and address the nutritional needs of adolescent girls, pregnant and lactating women and older persons"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, poner fin a todas las formas de malnutrición, incluso logrando, a más tardar en 2025, las metas convenidas internacionalmente sobre el retraso del crecimiento y la emaciación de los niños menores de 5 años, y abordar las necesidades de nutrición de las adolescentes, las mujeres embarazadas y lactantes y las personas de edad"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, mettre fin à toutes les formes de malnutrition, y compris en atteignant d’ici à 2025 les objectifs arrêtés à l’échelle internationale relatifs aux retards de croissance et à l’émaciation chez les enfants de moins de 5 ans, et répondre aux besoins nutritionnels des adolescentes, des femmes enceintes ou allaitantes et des personnes âgées"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020301"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020302"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@id" : "http://metadata.un.org/thesaurus/1002434"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000080"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020301"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020302"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.03"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.3"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.3"
  }, {
    "@language" : "en",
    "@value" : "Target 2.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, double the agricultural productivity and incomes of small-scale food producers, in particular women, indigenous peoples, family farmers, pastoralists and fishers, including through secure and equal access to land, other productive resources and inputs, knowledge, financial services, markets and opportunities for value addition and non-farm employment"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, duplicar la productividad agrícola y los ingresos de los productores de alimentos en pequeña escala, en particular las mujeres, los pueblos indígenas, los agricultores familiares, los ganaderos y los pescadores, entre otras cosas mediante un acceso seguro y equitativo a las tierras, a otros recursos e insumos de producción y a los conocimientos, los servicios financieros, los mercados y las oportunidades para añadir valor y obtener empleos no agrícolas "
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, doubler la productivité agricole et les revenus des petits producteurs alimentaires, en particulier des femmes, des autochtones, des exploitants familiaux, des éleveurs et des pêcheurs, y compris en assurant l’égalité d’accès aux terres, aux autres ressources productives et facteurs de production, au savoir, aux services financiers, aux marchés et aux possibilités d’ajout de valeur et d’emplois autres qu’agricoles"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020401"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000081"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020401"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.04"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.4"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.4"
  }, {
    "@language" : "en",
    "@value" : "Target 2.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, ensure sustainable food production systems and implement resilient agricultural practices that increase productivity and production, that help maintain ecosystems, that strengthen capacity for adaptation to climate change, extreme weather, drought, flooding and other disasters and that progressively improve land and soil quality"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, asegurar la sostenibilidad de los sistemas de producción de alimentos y aplicar prácticas agrícolas resilientes que aumenten la productividad y la producción, contribuyan al mantenimiento de los ecosistemas, fortalezcan la capacidad de adaptación al cambio climático, los fenómenos meteorológicos extremos, las sequías, las inundaciones y otros desastres, y mejoren progresivamente la calidad de la tierra y el suelo"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, assurer la viabilité des systèmes de production alimentaire et mettre en œuvre des pratiques agricoles résilientes qui permettent d’accroître la productivité et la production, contribuent à la préservation des écosystèmes, renforcent la capacité d’adaptation aux changements climatiques, aux phénomènes météorologiques extrêmes, à la sécheresse, aux inondations et à d’autres catastrophes et améliorent progressivement la qualité des terres et des sols"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020501"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020502"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000082"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020501"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020502"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.05"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.5"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.5"
  }, {
    "@language" : "en",
    "@value" : "Target 2.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2020, maintain the genetic diversity of seeds, cultivated plants and farmed and domesticated animals and their related wild species, including through soundly managed and diversified seed and plant banks at the national, regional and international levels, and promote access to and fair and equitable sharing of benefits arising from the utilization of genetic resources and associated traditional knowledge, as internationally agreed"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2020, mantener la diversidad genética de las semillas, las plantas cultivadas y los animales de granja y domesticados y sus correspondientes especies silvestres, entre otras cosas mediante una buena gestión y diversificación de los bancos de semillas y plantas a nivel nacional, regional e internacional, y promover el acceso a los beneficios que se deriven de la utilización de los recursos genéticos y los conocimientos tradicionales conexos y su distribución justa y equitativa, según lo convenido internacionalmente"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2020, préserver la diversité génétique des semences, des cultures et des animaux d’élevage ou domestiqués et des espèces sauvages apparentées, y compris au moyen de banques de semences et de plantes bien gérées et diversifiées aux niveaux national, régional et international, et favoriser l’accès aux avantages que présentent l’utilisation des ressources génétiques et du savoir traditionnel associé ainsi que le partage juste et équitable de ces avantages, comme convenu à l’échelle internationale"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.a",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020a01"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020a02"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@id" : "http://eurovoc.europa.eu/2442"
  }, {
    "@id" : "http://eurovoc.europa.eu/2497"
  }, {
    "@id" : "http://eurovoc.europa.eu/2577"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1000150"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1001863"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000083"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020a01"
  }, {
    "@id" : "http://metadata.un.org/sdg/C020a02"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.0a"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.a"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.a"
  }, {
    "@language" : "en",
    "@value" : "Target 2.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Accroître, notamment grâce au renforcement de la coopération internationale, l’investissement dans l’infrastructure rurale, les services de recherche et de vulgarisation agricoles et la mise au point de technologies et de banques de plantes et de gènes d’animaux d’élevage, afin de renforcer les capacités productives agricoles des pays en développement, en particulier des pays les moins avancés"
  }, {
    "@language" : "es",
    "@value" : "Aumentar, incluso mediante una mayor cooperación internacional, las inversiones en infraestructura rural, investigación y servicios de extensión agrícola, desarrollo tecnológico y bancos de genes de plantas y ganado a fin de mejorar la capacidad de producción agropecuaria en los países en desarrollo, particularmente en los países menos adelantados"
  }, {
    "@language" : "en",
    "@value" : "Increase investment, including through enhanced international cooperation, in rural infrastructure, agricultural research and extension services, technology development and plant and livestock gene banks in order to enhance agricultural productive capacity in developing countries, in particular least developed countries"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.b",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020b02"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000084"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020b02"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.0b"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.b"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.b"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.b"
  }, {
    "@language" : "en",
    "@value" : "Target 2.b"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Correct and prevent trade restrictions and distortions in world agricultural markets, including through the parallel elimination of all forms of agricultural export subsidies and all export measures with equivalent effect, in accordance with the mandate of the Doha Development Round"
  }, {
    "@language" : "es",
    "@value" : "Corregir y prevenir las restricciones y distorsiones comerciales en los mercados agropecuarios mundiales, incluso mediante la eliminación paralela de todas las formas de subvención a las exportaciones agrícolas y todas las medidas de exportación con efectos equivalentes, de conformidad con el mandato de la Ronda de Doha para el Desarrollo"
  }, {
    "@language" : "fr",
    "@value" : "Corriger et prévenir les restrictions et distorsions entravant le fonctionnement des marchés agricoles mondiaux, y compris par l’élimination parallèle de toutes les formes de subventions aux exportations agricoles et de toutes les mesures à l’exportation ayant un effet équivalent, conformément au mandat du Cycle de négociations de Doha pour le développement"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/2.c",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C020c01"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@id" : "http://eurovoc.europa.eu/2577"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1002431"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/2"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000085"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C020c01"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "02.0c"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "2.c"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 2.c"
  }, {
    "@language" : "es",
    "@value" : "Meta 2.c"
  }, {
    "@language" : "en",
    "@value" : "Target 2.c"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Adopt measures to ensure the proper functioning of food commodity markets and their derivatives and facilitate timely access to market information, including on food reserves, in order to help limit extreme food price volatility"
  }, {
    "@language" : "es",
    "@value" : "Adoptar medidas para asegurar el buen funcionamiento de los mercados de productos básicos alimentarios y sus derivados y facilitar el acceso oportuno a la información sobre los mercados, incluso sobre las reservas de alimentos, a fin de ayudar a limitar la extrema volatilidad de los precios de los alimentos"
  }, {
    "@language" : "fr",
    "@value" : "Adopter des mesures visant à assurer le bon fonctionnement des marchés de denrées alimentaires et de produits dérivés et à faciliter l’accès rapide aux informations relatives à ces marchés, y compris le niveau des réserves alimentaires, afin de contribuer à limiter l’extrême volatilité des prix alimentaires"
  } ]
}, {
