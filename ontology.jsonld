  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C200207"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "15.0a"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "15.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 15.a"
  }, {
    "@language" : "es",
    "@value" : "Meta 15.a"
  }, {
    "@language" : "en",
    "@value" : "Target 15.a"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Mobiliser des ressources financières de toutes provenances et les augmenter nettement pour préserver la biodiversité et les écosystèmes et les exploiter durablement"
  }, {
    "@language" : "en",
    "@value" : "Mobilize and significantly increase financial resources from all sources to conserve and sustainably use biodiversity and ecosystems"
  }, {
    "@language" : "es",
    "@value" : "Movilizar y aumentar significativamente los recursos financieros procedentes de todas las fuentes para conservar y utilizar de forma sostenible la biodiversidad y los ecosistemas"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/15.b",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C200207"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/15"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@id" : "http://eurovoc.europa.eu/2577"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/021000"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1000612"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1001619"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1001623"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1002625"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/15"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000208"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C200207"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "15.0b"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "15.b"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 15.b"
  }, {
    "@language" : "es",
    "@value" : "Meta 15.b"
  }, {
    "@language" : "en",
    "@value" : "Target 15.b"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Mobiliser d’importantes ressources de toutes provenances et à tous les niveaux pour financer la gestion durable des forêts et inciter les pays en développement à privilégier ce type de gestion, notamment aux fins de la préservation des forêts et du reboisement"
  }, {
    "@language" : "en",
    "@value" : "Mobilize significant resources from all sources and at all levels to finance sustainable forest management and provide adequate incentives to developing countries to advance such management, including for conservation and reforestation"
  }, {
    "@language" : "es",
    "@value" : "Movilizar recursos considerables de todas las fuentes y a todos los niveles para financiar la gestión forestal sostenible y proporcionar incentivos adecuados a los países en desarrollo para que promuevan dicha gestión, en particular con miras a la conservación y la reforestación"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/15.c",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C200206"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/15"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/15"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000209"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C200206"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "15.0c"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "15.c"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 15.c"
  }, {
    "@language" : "es",
    "@value" : "Meta 15.c"
  }, {
    "@language" : "en",
    "@value" : "Target 15.c"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Apporter, à l’échelon mondial, un soutien accru à l’action menée pour lutter contre le braconnage et le trafic d’espèces protégées, notamment en donnant aux populations locales d’autres moyens d’assurer durablement leur subsistance"
  }, {
    "@language" : "es",
    "@value" : "Aumentar el apoyo mundial a la lucha contra la caza furtiva y el tráfico de especies protegidas, incluso aumentando la capacidad de las comunidades locales para perseguir oportunidades de subsistencia sostenibles"
  }, {
    "@language" : "en",
    "@value" : "Enhance global support for efforts to combat poaching and trafficking of protected species, including by increasing the capacity of local communities to pursue sustainable livelihood opportunities"
  } ]
}, {
