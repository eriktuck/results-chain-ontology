    "@language" : "fr",
    "@value" : "Objectif 8"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 8"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Promote sustained, inclusive and sustainable economic growth, full and productive employment and decent work for all"
  }, {
    "@language" : "fr",
    "@value" : "Promouvoir une croissance économique soutenue, partagée et durable, le plein emploi productif et un travail décent pour tous"
  }, {
    "@language" : "es",
    "@value" : "Promover el crecimiento económico sostenido, inclusivo y sostenible, el empleo pleno y productivo y el trabajo decente para todos"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
