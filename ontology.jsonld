    "@language" : "fr",
    "@value" : "Cible 12.5"
  }, {
    "@language" : "es",
    "@value" : "Meta 12.5"
  }, {
    "@language" : "en",
    "@value" : "Target 12.5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, substantially reduce waste generation through prevention, reduction, recycling and reuse"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, reducir considerablemente la generación de desechos mediante actividades de prevención, reducción, reciclado y reutilización"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, réduire nettement la production de déchets par la prévention, la réduction, le recyclage et la réutilisation"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/12.6",
