    "@value" : "5"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 5"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 5"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Achieve gender equality and empower all women and girls"
  }, {
    "@language" : "es",
    "@value" : "Lograr la igualdad de género y empoderar a todas las mujeres y las niñas"
  }, {
    "@language" : "fr",
    "@value" : "Parvenir à l’égalité des sexes et autonomiser toutes les femmes et les filles"
  } ],
