  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, increase substantially the share of renewable energy in the global energy mix"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, aumentar considerablemente la proporción de energía renovable en el conjunto de fuentes energéticas"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, accroître nettement la part de l’énergie renouvelable dans le bouquet énergétique mondial"
  } ]
