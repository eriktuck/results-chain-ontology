  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "08.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "8.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 8.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 8.1"
  }, {
    "@language" : "en",
    "@value" : "Target 8.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Maintenir un taux de croissance économique par habitant adapté au contexte national et, en particulier, un taux de croissance annuelle du produit intérieur brut d’au moins 7 pour cent dans les pays les moins avancés"
  }, {
    "@language" : "es",
    "@value" : "Mantener el crecimiento económico per cápita de conformidad con las circunstancias nacionales y, en particular, un crecimiento del producto interno bruto de al menos el 7% anual en los países menos adelantados"
  }, {
    "@language" : "en",
    "@value" : "Sustain per capita economic growth in accordance with national circumstances and, in particular, at least 7 per cent gross domestic product growth per annum in the least developed countries"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/8.10",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C081001"
  }, {
    "@id" : "http://metadata.un.org/sdg/C081002"
  } ],
