  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Reducir significativamente todas las formas de violencia y las correspondientes tasas de mortalidad en todo el mundo"
  }, {
    "@language" : "fr",
    "@value" : "Réduire nettement, partout dans le monde, toutes les formes de violence et les taux de mortalité qui y sont associés"
