  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Actions monitoring and enforcing compliance with existing laws and policies at all levels to deter threats or compel conservation action"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Law Enforcement & Prosecution"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#4.1",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Detecting, directly stopping, and/or deterring violations of existing laws and policies"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Detection & Arrest"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#4.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Ensuring appropriate application of sanctions for violations of existing laws and policies"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Criminal Prosecution & Conviction"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#4.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#4"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Threatening or bringing non-criminal legal action to get individuals, organizations, agencies or firms to change or deter undesired behaviors or compel conservation action"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "https://conservationstandards.org/library-item/actions-classification#ActionScheme"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "4.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Non-Criminal Legal Action"
  } ]
}, {
  "@id" : "https://conservationstandards.org/library-item/actions-classification#5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
