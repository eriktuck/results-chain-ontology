  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 3.4"
  }, {
    "@language" : "es",
    "@value" : "Meta 3.4"
  }, {
    "@language" : "en",
    "@value" : "Target 3.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, reduce by one third premature mortality from non-communicable diseases through prevention and treatment and promote mental health and well-being"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, reducir en un tercio la mortalidad prematura por enfermedades no transmisibles mediante su prevención y tratamiento, y promover la salud mental y el bienestar"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, réduire d’un tiers, par la prévention et le traitement, le taux de mortalité prématurée due à des maladies non transmissibles et promouvoir la santé mentale et le bien-être"
  } ]
