  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "17.04"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "17.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 17.4"
  }, {
    "@language" : "es",
    "@value" : "Meta 17.4"
  }, {
    "@language" : "en",
    "@value" : "Target 17.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Aider les pays en développement à assurer la viabilité à long terme de leur dette au moyen de politiques concertées visant à favoriser le financement de la dette, son allégement ou sa restructuration, selon le cas, et réduire le surendettement en réglant le problème de la dette extérieure des pays pauvres très endettés"
  }, {
    "@language" : "en",
    "@value" : "Assist developing countries in attaining long-term debt sustainability through coordinated policies aimed at fostering debt financing, debt relief and debt restructuring, as appropriate, and address the external debt of highly indebted poor countries to reduce debt distress"
  }, {
    "@language" : "es",
    "@value" : "Ayudar a los países en desarrollo a lograr la sostenibilidad de la deuda a largo plazo con políticas coordinadas orientadas a fomentar la financiación, el alivio y la reestructuración de la deuda, según proceda, y hacer frente a la deuda externa de los países pobres muy endeudados a fin de reducir el endeudamiento excesivo"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/17.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
