    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "14.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "14.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 14.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 14.1"
  }, {
    "@language" : "en",
    "@value" : "Target 14.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2025, prevent and significantly reduce marine pollution of all kinds, in particular from land-based activities, including marine debris and nutrient pollution"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2025, prevenir y reducir significativamente la contaminación marina de todo tipo, en particular la producida por actividades realizadas en tierra, incluidos los detritos marinos y la polución por nutrientes"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2025, prévenir et réduire nettement la pollution marine de tous types, en particulier celle résultant des activités terrestres, y compris les déchets en mer et la pollution par les nutriments"
  } ]
