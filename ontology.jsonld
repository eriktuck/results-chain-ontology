  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, provide legal identity for all, including birth registration"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, proporcionar acceso a una identidad jurídica para todos, en particular mediante el registro de nacimientos"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, garantir à tous une identité juridique, notamment grâce à l’enregistrement des naissances"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/16.a",
