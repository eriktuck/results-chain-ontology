    "@value" : "13"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "13"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 13"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 13"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 13"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Adoptar medidas urgentes para combatir el cambio climático y sus efectos"
  }, {
    "@language" : "fr",
    "@value" : "Prendre d’urgence des mesures pour lutter contre les changements climatiques et leurs répercussions"
  }, {
    "@language" : "en",
    "@value" : "Take urgent action to combat climate change and its impacts"
  } ],
  "http://www.w3.org/2004/02/skos/core#topConceptOf" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ]
