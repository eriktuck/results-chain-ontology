  }, {
    "@language" : "es",
    "@value" : "Meta 17.13"
  }, {
    "@language" : "en",
    "@value" : "Target 17.13"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Aumentar la estabilidad macroeconómica mundial, incluso mediante la coordinación y coherencia de las políticas"
  }, {
    "@language" : "en",
    "@value" : "Enhance global macroeconomic stability, including through policy coordination and policy coherence"
  }, {
    "@language" : "fr",
    "@value" : "Renforcer la stabilité macroéconomique mondiale, notamment en favorisant la coordination et la  and domestic material consumption per GDP"
  } ]
