  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://eriktuck.github.io/results-chain-ontology#Strategy"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "addresses"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult"
  } ]
}, {
  "@id" : "https://eriktuck.github.io/results-chain-ontology#hasIndicator",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Links a result or impact to a specific measurable indicator."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid3"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "has indicator"
