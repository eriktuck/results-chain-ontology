  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Promote the rule of law at the national and international levels and ensure equal access to justice for all"
  }, {
    "@language" : "fr",
    "@value" : "Promouvoir l’état de droit dans l’ordre interne et international et garantir à tous un égal accès à la justice"
  }, {
    "@language" : "es",
    "@value" : "Promover el estado de derecho en los planos nacional e internacional y garantizar la igualdad de acceso a la justicia para todos"
  } ]
