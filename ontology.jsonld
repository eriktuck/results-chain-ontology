  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Fortalecer la resiliencia y la capacidad de adaptación a los riesgos relacionados con el clima y los desastres naturales en todos los países"
  }, {
    "@language" : "fr",
    "@value" : "Renforcer, dans tous les pays, la résilience et les capacités d’adaptation face aux aléas climatiques et aux catastrophes naturelles liées au climat"
  }, {
    "@language" : "en",
    "@value" : "Strengthen resilience and adaptive capacity to climate-related hazards and natural disasters in all countries"
  } ]
