    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "14"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "14"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 14"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 14"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 14"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Conservar y utilizar sosteniblemente los océanos, los mares y los recursos marinos para el desarrollo sostenible"
  }, {
    "@language" : "en",
    "@value" : "Conserve and sustainably use the oceans, seas and marine resources for sustainable development"
  }, {
    "@language" : "fr",
    "@value" : "Conserver et exploiter de manière durable les océans, les mers et les ressources marines aux fins du développement durable"
  } ],
