  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "03"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "3"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "en",
    "@value" : "Goal 3"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 3"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Ensure healthy lives and promote well-being for all at all ages"
  }, {
    "@language" : "es",
    "@value" : "Garantizar una vida sana y promover el bienestar de todos a todas las edades"
  }, {
    "@language" : "fr",
    "@value" : "Permettre à tous de vivre en bonne santé et promouvoir le bien-être de tous à tout âge"
  } ],
