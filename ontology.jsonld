  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The specific variable used to measure progress toward a result or impact. Map to UNBIS."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Indicator"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@value" : "Align with UNBIS Thesaurus via skos:related"
  } ]
}, {
  "@id" : "https://eriktuck.github.io/results-chain-ontology#Result",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A generic term used to describe the desired future state of a factor. Includes intermediate outcomes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Result"
  } ]
}, {
  "@id" : "https://eriktuck.github.io/results-chain-ontology#Strategy",
