  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A specific result where a direct threat is diminished. Map to CMP Threats."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Threat Reduction Result"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://eriktuck.github.io/results-chain-ontology#Result"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@value" : "Align with CMP Threat Taxonomy via skos:related"
  } ]
}, {
  "@id" : "https://eriktuck.github.io/results-chain-ontology#addresses",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
