  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Enhance policy coherence for sustainable development"
  }, {
    "@language" : "es",
    "@value" : "Mejorar la coherencia de las políticas para el desarrollo sostenible"
  }, {
    "@language" : "fr",
    "@value" : "Renforcer la cohérence des politiques de développement durable"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/17.15",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
