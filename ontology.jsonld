  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "es",
    "@value" : "Incorporar medidas relativas al cambio climático en las políticas, estrategias y planes nacionales"
  }, {
    "@language" : "fr",
    "@value" : "Incorporer des mesures relatives aux changements climatiques dans les politiques, les stratégies et la planification nationales"
  }, {
    "@language" : "en",
    "@value" : "Integrate climate change measures into national policies, strategies and planning"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/13.3",
