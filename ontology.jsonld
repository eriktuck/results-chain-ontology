  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Strategy"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@value" : "Align with CMP Action Taxonomy via skos:exactMatch"
  } ]
}, {
  "@id" : "https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult",
