    "@language" : "en",
    "@value" : "Goal 11"
  }, {
    "@language" : "fr",
    "@value" : "Objectif 11"
  }, {
    "@language" : "es",
    "@value" : "Objetivo 11"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Faire en sorte que les villes et les établissements humains soient ouverts à tous, sûrs, résilients et durables"
  }, {
    "@language" : "es",
    "@value" : "Lograr que las ciudades y los asentamientos humanos sean inclusivos, seguros, resilientes y sostenibles"
  }, {
    "@language" : "en",
    "@value" : "Make cities and human settlements inclusive, safe, resilient and sustainable"
  } ],
