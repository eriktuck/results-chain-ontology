  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000151"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C100101"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "10.01"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "10.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.1"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.1"
  }, {
    "@language" : "en",
    "@value" : "Target 10.1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, progressively achieve and sustain income growth of the bottom 40 per cent of the population at a rate higher than the national average"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, lograr progresivamente y mantener el crecimiento de los ingresos del 40% más pobre de la población a una tasa superior a la media nacional"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, assurer progressivement et durablement une croissance des revenus des 40 pour cent de la population les plus pauvres à un rythme plus rapide que le revenu moyen national"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.2",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C100201"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000152"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C100201"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "10.02"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "10.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.2"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.2"
  }, {
    "@language" : "en",
    "@value" : "Target 10.2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, empower and promote the social, economic and political inclusion of all, irrespective of age, sex, disability, race, ethnicity, origin, religion or economic or other status"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, potenciar y promover la inclusión social, económica y política de todas las personas, independientemente de su edad, sexo, discapacidad, raza, etnia, origen, religión o situación económica u otra condición"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, autonomiser toutes les personnes et favoriser leur intégration sociale, économique et politique, indépendamment de leur âge, de leur sexe, de leur handicap, de leur race, de leur appartenance ethnique, de leurs origines, de leur religion ou de leur statut économique ou autre"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C200204"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000153"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C200204"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "10.03"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "10.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.3"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.3"
  }, {
    "@language" : "en",
    "@value" : "Target 10.3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Assurer l’égalité des chances et réduire l’inégalité des résultats, notamment en éliminant les lois, politiques et pratiques discriminatoires et en encourageant l’adoption de lois, politiques et mesures adéquates en la matière"
  }, {
    "@language" : "en",
    "@value" : "Ensure equal opportunity and reduce inequalities of outcome, including by eliminating discriminatory laws, policies and practices and promoting appropriate legislation, policies and action in this regard"
  }, {
    "@language" : "es",
    "@value" : "Garantizar la igualdad de oportunidades y reducir la desigualdad de resultados, incluso eliminando las leyes, políticas y prácticas discriminatorias y promoviendo legislaciones, políticas y medidas adecuadas a ese respecto"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.4",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C100401"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://purl.org/dc/terms/subject" : [ {
    "@id" : "http://eurovoc.europa.eu/4050"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1003084"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1005985"
  }, {
    "@id" : "http://metadata.un.org/thesaurus/1006915"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://metadata.un.org/sdg/ontology#Target"
  }, {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#broader" : [ {
    "@id" : "http://metadata.un.org/sdg/10"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://purl.unep.org/sdg/SDGIO_00000154"
  } ],
  "http://www.w3.org/2004/02/skos/core#inScheme" : [ {
    "@id" : "http://metadata.un.org/sdg"
  } ],
  "http://www.w3.org/2004/02/skos/core#narrower" : [ {
    "@id" : "http://metadata.un.org/sdg/C100401"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "10.04"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "10.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 10.4"
  }, {
    "@language" : "es",
    "@value" : "Meta 10.4"
  }, {
    "@language" : "en",
    "@value" : "Target 10.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Adopt policies, especially fiscal, wage and social protection policies, and progressively achieve greater equality"
  }, {
    "@language" : "es",
    "@value" : "Adoptar políticas, especialmente fiscales, salariales y de protección social, y lograr progresivamente una mayor igualdad"
  }, {
    "@language" : "fr",
    "@value" : "Adopter des politiques, notamment sur les plans budgétaire, salarial et dans le domaine de la protection sociale, afin de parvenir progressivement à une plus grande égalité"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/10.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C100501"
  } ],
  "http://metadata.un.org/sdg/ontology#isTargetOf" : [ {
