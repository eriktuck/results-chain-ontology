  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCode",
    "@value" : "05.04"
  }, {
    "@type" : "http://metadata.un.org/sdg/ontology#SDGCodeCompact",
    "@value" : "5.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#note" : [ {
    "@language" : "fr",
    "@value" : "Cible 5.4"
  }, {
    "@language" : "es",
    "@value" : "Meta 5.4"
  }, {
    "@language" : "en",
    "@value" : "Target 5.4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Prendre en compte et valoriser les soins et travaux domestiques non rémunérés, par la mise en place de services publics, d’infrastructures et de politiques de protection sociale et par la promotion du partage des responsabilités dans le ménage et la famille, en fonction du contexte national"
  }, {
    "@language" : "en",
    "@value" : "Recognize and value unpaid care and domestic work through the provision of public services, infrastructure and social protection policies and the promotion of shared responsibility within the household and the family as nationally appropriate"
  }, {
    "@language" : "es",
    "@value" : "Reconocer y valorar los cuidados y el trabajo doméstico no remunerados mediante servicios públicos, infraestructuras y políticas de protección social, y promoviendo la responsabilidad compartida en el hogar y la familia, según proceda en cada país"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/5.5",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://metadata.un.org/sdg/ontology#hasIndicator" : [ {
    "@id" : "http://metadata.un.org/sdg/C050501"
