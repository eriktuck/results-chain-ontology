  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fr",
    "@value" : "Nombre de stratégies ou de politiques en place dans le domaine du tourisme durable et de plans d’action mis en œuvre en appliquant des outils d’évaluation et de suivi convenus "
  }, {
    "@language" : "en",
    "@value" : "Number of sustainable tourism strategies or policies and implemented action plans with agreed monitoring and evaluation tools"
  }, {
    "@language" : "es",
    "@value" : "Número de estrategias o políticas de turismo sostenible y de planes de acción aplicados que incluyen instrumentos de seguimiento y evaluación convenidos"
  } ]
