    "@language" : "fr",
    "@value" : "Cible 8.9"
  }, {
    "@language" : "es",
    "@value" : "Meta 8.9"
  }, {
    "@language" : "en",
    "@value" : "Target 8.9"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "By 2030, devise and implement policies to promote sustainable tourism that creates jobs and promotes local culture and products"
  }, {
    "@language" : "es",
    "@value" : "De aquí a 2030, elaborar y poner en práctica políticas encaminadas a promover un turismo sostenible que cree puestos de trabajo y promueva la cultura y los productos locales"
  }, {
    "@language" : "fr",
    "@value" : "D’ici à 2030, élaborer et mettre en œuvre des politiques visant à développer un tourisme durable qui crée des emplois et met en valeur la culture et les produits locaux"
  } ]
}, {
  "@id" : "http://metadata.un.org/sdg/8.a",
