                                               "3.5"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 3.5"@fr ,
                                           "Meta 3.5"@es ,
                                           "Target 3.5"@en ;
                                 skos:prefLabel "Fortalecer la prevención y el tratamiento del abuso de sustancias adictivas, incluido el uso indebido de estupefacientes y el consumo nocivo de alcohol"@es ,
                                                "Renforcer la prévention et le traitement de l’abus de substances psychoactives, notamment de stupéfiants et d’alcool"@fr ,
                                                "Strengthen the prevention and treatment of substance abuse, including narcotic drug abuse and harmful use of alcohol"@en .


###  http://metadata.un.org/sdg/3.6
<http://metadata.un.org/sdg/3.6> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C030601> ;
