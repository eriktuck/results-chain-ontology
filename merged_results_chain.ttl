                                   skos:inScheme <http://metadata.un.org/sdg> ;
                                   skos:notation "17.13"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                 "17.13"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                   skos:note "Cible 17.13"@fr ,
                                             "Meta 17.13"@es ,
                                             "Target 17.13"@en ;
                                   skos:prefLabel "Aumentar la estabilidad macroeconómica mundial, incluso mediante la coordinación y coherencia de las políticas"@es ,
                                                  "Enhance global macroeconomic stability, including through policy coordination and policy coherence"@en ,
                                                  "Renforcer la stabilité macroéconomique mondiale, notamment en favorisant la coordination et la  and domestic material consumption per GDP"@fr .


###  http://metadata.un.org/sdg/17.14
<http://metadata.un.org/sdg/17.14> rdf:type owl:NamedIndividual ,
                                            <http://metadata.un.org/sdg/ontology#Target> ,
                                            skos:Concept ;
                                   <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C171401> ;
                                   <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/17> ;
                                   skos:broader <http://metadata.un.org/sdg/17> ;
                                   skos:narrower <http://metadata.un.org/sdg/C171401> ;
