                                                                     <http://metadata.un.org/thesaurus/1001613> ,
                                                                     <http://metadata.un.org/thesaurus/1005517> ;
                                  skos:broader <http://metadata.un.org/sdg/17> ;
                                  skos:narrower <http://metadata.un.org/sdg/C170101> ,
