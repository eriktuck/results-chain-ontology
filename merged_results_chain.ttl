@prefix : <https://eriktuck.github.io/results-chain-ontology/> .
@prefix rc: <https://eriktuck.github.io/results-chain-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <https://eriktuck.github.io/results-chain-ontology/> .

<https://eriktuck.github.io/results-chain-ontology/> rdf:type owl:Ontology ;
                                                      rdfs:comment "A simple ontology based on Margoluis et al. (2013) to represent Theories of Change in conservation." ;
                                                      rdfs:label "Conservation Results Chain Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://schema.org/identifier
<http://schema.org/identifier> rdf:type owl:AnnotationProperty .


###  http://schema.org/name
<http://schema.org/name> rdf:type owl:AnnotationProperty .


###  http://schema.org/version
<http://schema.org/version> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broadMatch
skos:broadMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#historyNote
skos:historyNote rdf:type owl:AnnotationProperty ;
                 rdfs:subPropertyOf <http://schema.org/version> .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#memberList
skos:memberList rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#notation
skos:notation rdf:type owl:AnnotationProperty ;
              rdfs:subPropertyOf <http://schema.org/identifier> .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty ;
               rdfs:subPropertyOf <http://schema.org/name> .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
skos:topConceptOf rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://metadata.un.org/sdg/ontology#SDGCode
<http://metadata.un.org/sdg/ontology#SDGCode> rdf:type rdfs:Datatype ;
                                              rdfs:label "Standard SDG code"@en .


###  http://metadata.un.org/sdg/ontology#SDGCodeCompact
<http://metadata.un.org/sdg/ontology#SDGCodeCompact> rdf:type rdfs:Datatype ;
                                                     rdfs:label "Standard SDG code in the compact format"@en .


###  http://metadata.un.org/sdg/ontology#SDGCodePerm
<http://metadata.un.org/sdg/ontology#SDGCodePerm> rdf:type rdfs:Datatype ;
                                                  rdfs:label "Permanent SDG indicator code"@en .


#################################################################
#    Object Properties
#################################################################

###  http://metadata.un.org/sdg/ontology#hasIndicator
<http://metadata.un.org/sdg/ontology#hasIndicator> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf skos:narrower ;
                                                   owl:inverseOf <http://metadata.un.org/sdg/ontology#isIndicatorOf> ;
                                                   rdfs:domain <http://metadata.un.org/sdg/ontology#Target> ;
                                                   rdfs:range <http://metadata.un.org/sdg/ontology#Indicator> ;
                                                   rdfs:label "has indicator"@en .


###  http://metadata.un.org/sdg/ontology#hasSeries
<http://metadata.un.org/sdg/ontology#hasSeries> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf skos:narrower ;
                                                owl:inverseOf <http://metadata.un.org/sdg/ontology#isSeriesOf> ;
                                                rdfs:domain <http://metadata.un.org/sdg/ontology#Indicator> ;
                                                rdfs:range <http://metadata.un.org/sdg/ontology#Series> ;
                                                rdfs:label "has series"@en .


###  http://metadata.un.org/sdg/ontology#hasTarget
<http://metadata.un.org/sdg/ontology#hasTarget> rdf:type owl:ObjectProperty ;
                                                rdfs:subPropertyOf skos:narrower ;
                                                owl:inverseOf <http://metadata.un.org/sdg/ontology#isTargetOf> ;
                                                rdfs:domain <http://metadata.un.org/sdg/ontology#Goal> ;
                                                rdfs:range <http://metadata.un.org/sdg/ontology#Target> ;
                                                rdfs:label "has target"@en .


###  http://metadata.un.org/sdg/ontology#isIndicatorOf
<http://metadata.un.org/sdg/ontology#isIndicatorOf> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf skos:broader ;
                                                    rdfs:domain <http://metadata.un.org/sdg/ontology#Indicator> ;
                                                    rdfs:range <http://metadata.un.org/sdg/ontology#Target> ;
                                                    rdfs:label "is indicator of"@en .


###  http://metadata.un.org/sdg/ontology#isSeriesOf
<http://metadata.un.org/sdg/ontology#isSeriesOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf skos:broader ;
                                                 rdfs:domain <http://metadata.un.org/sdg/ontology#Series> ;
                                                 rdfs:range <http://metadata.un.org/sdg/ontology#Indicator> ;
                                                 rdfs:label "is series of"@en .


###  http://metadata.un.org/sdg/ontology#isTargetOf
<http://metadata.un.org/sdg/ontology#isTargetOf> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf skos:broader ;
                                                 rdfs:domain <http://metadata.un.org/sdg/ontology#Target> ;
                                                 rdfs:range <http://metadata.un.org/sdg/ontology#Goal> ;
                                                 rdfs:label "is target of"@en .


###  http://metadata.un.org/sdg/ontology#tier
<http://metadata.un.org/sdg/ontology#tier> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://metadata.un.org/sdg/ontology#Indicator> ;
                                           rdfs:range <http://metadata.un.org/sdg/ontology#Tier> ;
                                           rdfs:label "tier"@en .


###  http://purl.org/dc/terms/subject
<http://purl.org/dc/terms/subject> rdf:type owl:ObjectProperty ;
                                   rdfs:domain skos:Concept ;
                                   rdfs:range skos:Concept .


###  http://schema.org/keywords
<http://schema.org/keywords> rdf:type owl:ObjectProperty ;
                             owl:propertyChainAxiom ( <http://purl.org/dc/terms/subject>
                                                      skos:prefLabel
                                                    ) .


###  http://www.w3.org/2004/02/skos/core#narrower
skos:narrower rdf:type owl:ObjectProperty .


###  https://eriktuck.github.io/results-chain-ontology#addresses
rc:addresses rdf:type owl:ObjectProperty ;
             rdfs:domain rc:Strategy ;
             rdfs:range rc:ThreatReductionResult ;
             rdfs:comment "Links a strategy directly to the threat it intends to mitigate." ;
             rdfs:label "addresses" .


###  https://eriktuck.github.io/results-chain-ontology#hasIndicator
rc:hasIndicator rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( rc:Impact
                                            rc:Result
                                          )
                            ] ;
                rdfs:range rc:Indicator ;
                rdfs:comment "Links a result or impact to a specific measurable indicator." ;
                rdfs:label "has indicator" .


###  https://eriktuck.github.io/results-chain-ontology#leadsTo
rc:leadsTo rdf:type owl:ObjectProperty ,
                    owl:TransitiveProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( rc:Result
                                       rc:Strategy
                                     )
                       ] ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( rc:Impact
                                      rc:Result
                                    )
                      ] ;
           rdfs:comment "The causal or logical link between a strategy and a result, or between results." ;
           rdfs:label "leads to" .


###  https://eriktuck.github.io/results-chain-ontology#occursIn
rc:occursIn rdf:type owl:ObjectProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( rc:Impact
                                        rc:Result
                                        rc:Strategy
                                      )
                        ] ;
            rdfs:range rc:Context ;
            rdfs:comment "Links a component of the results chain to a specific geographic or institutional context." ;
            rdfs:label "occurs in" .


#################################################################
#    Data properties
#################################################################

###  http://metadata.un.org/sdg/ontology#custodianAgency
<http://metadata.un.org/sdg/ontology#custodianAgency> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://metadata.un.org/sdg/ontology#Indicator> ;
                                                      rdfs:range xsd:string ;
                                                      rdfs:label "has custodian agency"@en .


###  http://schema.org/keywords
<http://schema.org/keywords> rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://metadata.un.org/sdg/ontology#Goal
<http://metadata.un.org/sdg/ontology#Goal> rdf:type owl:Class ;
                                           rdfs:subClassOf skos:Concept ;
                                           rdfs:label "Goal"@en ,
                                                      "Objectif"@fr ,
                                                      "Objetivo"@es .


###  http://metadata.un.org/sdg/ontology#Indicator
<http://metadata.un.org/sdg/ontology#Indicator> rdf:type owl:Class ;
                                                rdfs:subClassOf skos:Concept ;
                                                rdfs:label "Indicador"@es ,
                                                           "Indicateur"@fr ,
                                                           "Indicator"@en .


###  http://metadata.un.org/sdg/ontology#Series
<http://metadata.un.org/sdg/ontology#Series> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://schema.org/Dataset> ,
                                                             skos:Concept ;
                                             rdfs:label "Series"@en .


###  http://metadata.un.org/sdg/ontology#Target
<http://metadata.un.org/sdg/ontology#Target> rdf:type owl:Class ;
                                             rdfs:subClassOf skos:Concept ;
                                             rdfs:label "Cible"@fr ,
                                                        "Meta"@es ,
                                                        "Target"@en .


###  http://metadata.un.org/sdg/ontology#Tier
<http://metadata.un.org/sdg/ontology#Tier> rdf:type owl:Class ;
                                           rdfs:label "Tier Classification for Global SDG Indicators"@en .


###  http://schema.org/Dataset
<http://schema.org/Dataset> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#OrderedCollection
skos:OrderedCollection rdf:type owl:Class .


###  https://eriktuck.github.io/results-chain-ontology#Context
rc:Context rdf:type owl:Class ;
           rdfs:comment "The external environment, including geographic locations and institutional entities. Populate via Wikifiers (Wikidata/DBpedia)." ;
           rdfs:label "Context" ;
           skos:note "Align with Wikidata/DBpedia URIs via owl:sameAs" .


###  https://eriktuck.github.io/results-chain-ontology#Impact
rc:Impact rdf:type owl:Class ;
          rdfs:comment "The desired future state of a conservation target (e.g., species, habitat). Map to ENVO." ;
          rdfs:label "Impact" ;
          skos:note "Align with ENVO via skos:narrowMatch" .


###  https://eriktuck.github.io/results-chain-ontology#Indicator
rc:Indicator rdf:type owl:Class ;
             rdfs:comment "The specific variable used to measure progress toward a result or impact. Map to UNBIS." ;
             rdfs:label "Indicator" ;
             skos:note "Align with UNBIS Thesaurus via skos:related" .


###  https://eriktuck.github.io/results-chain-ontology#Result
rc:Result rdf:type owl:Class ;
          rdfs:comment "A generic term used to describe the desired future state of a factor. Includes intermediate outcomes." ;
          rdfs:label "Result" .


###  https://eriktuck.github.io/results-chain-ontology#Strategy
rc:Strategy rdf:type owl:Class ;
            rdfs:comment "The set of actions or interventions that a project implements. Map to CMP Actions or Conservation Evidence Actions." ;
            rdfs:label "Strategy" ;
            skos:note "Align with CMP Action Taxonomy via skos:exactMatch" .


###  https://eriktuck.github.io/results-chain-ontology#ThreatReductionResult
rc:ThreatReductionResult rdf:type owl:Class ;
                         rdfs:subClassOf rc:Result ;
                         rdfs:comment "A specific result where a direct threat is diminished. Map to CMP Threats." ;
                         rdfs:label "Threat Reduction Result" ;
                         skos:note "Align with CMP Threat Taxonomy via skos:related" .


