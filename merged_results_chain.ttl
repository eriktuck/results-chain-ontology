<https://conservationstandards.org/library-item/threats-classification/#3> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#A> ;
                                                                           skos:definition "Extraction of non-biological resources, often widely dispersed across the land / sea scape."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "3" ;
                                                                           skos:prefLabel "Energy Production & Mining"@en .


