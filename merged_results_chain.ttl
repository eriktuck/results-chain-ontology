                               skos:note "Goal 5"@en ,
                                         "Objectif 5"@fr ,
                                         "Objetivo 5"@es ;
                               skos:prefLabel "Achieve gender equality and empower all women and girls"@en ,
                                              "Lograr la igualdad de género y empoderar a todas las mujeres y las niñas"@es ,
                                              "Parvenir à l’égalité des sexes et autonomiser toutes les femmes et les filles"@fr ;
                               skos:topConceptOf <http://metadata.un.org/sdg> .


###  http://metadata.un.org/sdg/5.a
<http://metadata.un.org/sdg/5.a> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050a01> ,
                                                                                    <http://metadata.un.org/sdg/C050a02> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/5> ;
                                 skos:broader <http://metadata.un.org/sdg/5> ;
                                 skos:narrower <http://metadata.un.org/sdg/C050a01> ,
                                               <http://metadata.un.org/sdg/C050a02> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000115> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "05.0a"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "5.a"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 5.a"@fr ,
                                           "Meta 5.a"@es ,
                                           "Target 5.a"@en ;
                                 skos:prefLabel "Emprender reformas que otorguen a las mujeres igualdad de derechos a los recursos económicos, así como acceso a la propiedad y al control de la tierra y otros tipos de bienes, los servicios financieros, la herencia y los recursos naturales, de conformidad con las leyes nacionales"@es ,
                                                "Entreprendre des réformes visant à donner aux femmes les mêmes droits aux ressources économiques, ainsi que l’accès à la propriété et au contrôle des terres et d’autres formes de propriété, aux services financiers, à l’héritage et aux ressources naturelles, dans le respect de la législation interne"@fr ,
                                                "Undertake reforms to give women equal rights to economic resources, as well as access to ownership and control over land and other forms of property, financial services, inheritance and natural resources, in accordance with national laws"@en .


###  http://metadata.un.org/sdg/5.b
<http://metadata.un.org/sdg/5.b> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050b01> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/5> ;
                                 <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/5188> ,
                                                                    <http://metadata.un.org/thesaurus/1001133> ,
                                                                    <http://metadata.un.org/thesaurus/1003205> ,
                                                                    <http://metadata.un.org/thesaurus/1004189> ;
                                 skos:broader <http://metadata.un.org/sdg/5> ;
                                 skos:narrower <http://metadata.un.org/sdg/C050b01> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000116> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "05.0b"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "5.b"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 5.b"@fr ,
                                           "Meta 5.b"@es ,
                                           "Target 5.b"@en ;
                                 skos:prefLabel "Enhance the use of enabling technology, in particular information and communications technology, to promote the empowerment of women"@en ,
                                                "Mejorar el uso de la tecnología instrumental, en particular la tecnología de la información y las comunicaciones, para promover el empoderamiento de las mujeres"@es ,
                                                "Renforcer l’utilisation des technologies clefs, en particulier de l’informatique et des communications, pour favoriser l’autonomisation des femmes"@fr .


###  http://metadata.un.org/sdg/5.c
<http://metadata.un.org/sdg/5.c> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050c01> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/5> ;
                                 skos:broader <http://metadata.un.org/sdg/5> ;
                                 skos:narrower <http://metadata.un.org/sdg/C050c01> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000117> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "05.0c"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "5.c"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 5.c"@fr ,
                                           "Meta 5.c"@es ,
                                           "Target 5.c"@en ;
                                 skos:prefLabel "Adopt and strengthen sound policies and enforceable legislation for the promotion of gender equality and the empowerment of all women and girls at all levels"@en ,
                                                "Adopter des politiques bien conçues et des dispositions législatives applicables en faveur de la promotion de l’égalité des sexes et de l’autonomisation de toutes les femmes et de toutes les filles à tous les niveaux et renforcer celles qui existent"@fr ,
                                                "Aprobar y fortalecer políticas acertadas y leyes aplicables para promover la igualdad de género y el empoderamiento de todas las mujeres y las niñas a todos los niveles"@es .


###  http://metadata.un.org/sdg/5.1
<http://metadata.un.org/sdg/5.1> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050101> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/5> ;
                                 skos:broader <http://metadata.un.org/sdg/5> ;
                                 skos:narrower <http://metadata.un.org/sdg/C050101> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000109> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "05.01"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "5.1"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 5.1"@fr ,
                                           "Meta 5.1"@es ,
                                           "Target 5.1"@en ;
                                 skos:prefLabel "End all forms of discrimination against all women and girls everywhere"@en ,
                                                "Mettre fin, partout dans le monde, à toutes les formes de discrimination à l’égard des femmes et des filles"@fr ,
                                                "Poner fin a todas las formas de discriminación contra todas las mujeres y las niñas en todo el mundo"@es .


###  http://metadata.un.org/sdg/5.2
<http://metadata.un.org/sdg/5.2> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050201> ,
                                                                                    <http://metadata.un.org/sdg/C050202> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/5> ;
                                 skos:broader <http://metadata.un.org/sdg/5> ;
                                 skos:narrower <http://metadata.un.org/sdg/C050201> ,
                                               <http://metadata.un.org/sdg/C050202> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000110> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "05.02"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "5.2"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 5.2"@fr ,
                                           "Meta 5.2"@es ,
                                           "Target 5.2"@en ;
                                 skos:prefLabel "Eliminar todas las formas de violencia contra todas las mujeres y las niñas en los ámbitos público y privado, incluidas la trata y la explotación sexual y otros tipos de explotación"@es ,
                                                "Eliminate all forms of violence against all women and girls in the public and private spheres, including trafficking and sexual and other types of exploitation"@en ,
                                                "Éliminer de la vie publique et de la vie privée toutes les formes de violence faite aux femmes et aux filles, y compris la traite et l’exploitation sexuelle et d’autres types d’exploitation"@fr .


###  http://metadata.un.org/sdg/5.3
<http://metadata.un.org/sdg/5.3> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C050301> ,
                                                                                    <http://metadata.un.org/sdg/C050302> ;
