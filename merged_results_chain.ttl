                                  skos:note "Cible 10.4"@fr ,
                                            "Meta 10.4"@es ,
                                            "Target 10.4"@en ;
                                  skos:prefLabel "Adopt policies, especially fiscal, wage and social protection policies, and progressively achieve greater equality"@en ,
                                                 "Adoptar políticas, especialmente fiscales, salariales y de protección social, y lograr progresivamente una mayor igualdad"@es ,
                                                 "Adopter des politiques, notamment sur les plans budgétaire, salarial et dans le domaine de la protection sociale, afin de parvenir progressivement à une plus grande égalité"@fr .


###  http://metadata.un.org/sdg/10.5
<http://metadata.un.org/sdg/10.5> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C100501> ;
                                  <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/10> ;
