                               skos:altLabel "Quality education"@en ;
                               skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000038> ,
                                               <http://www.wikidata.org/entity/Q53581209> ;
                               skos:inScheme <http://metadata.un.org/sdg> ;
                               skos:notation "04"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                             "4"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
