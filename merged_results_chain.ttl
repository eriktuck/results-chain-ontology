                                              <http://metadata.un.org/sdg/16.9> ;
                                skos:altLabel "Peace, justice and strong institutions"@en ;
                                skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000050> ,
                                                <http://www.wikidata.org/entity/Q53581248> ;
                                skos:inScheme <http://metadata.un.org/sdg> ;
                                skos:notation "16"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                              "16"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                skos:note "Goal 16"@en ,
                                          "Objectif 16"@fr ,
                                          "Objetivo 16"@es ;
                                skos:prefLabel "Promote peaceful and inclusive societies for sustainable development, provide access to justice for all and build effective, accountable and inclusive institutions at all levels"@en ,
                                               "Promouvoir l’avènement de sociétés pacifiques et inclusives aux fins du développement durable, assurer l’accès de tous à la justice et mettre en place, à tous les niveaux, des institutions efficaces, responsables et ouvertes à tous"@fr ,
                                               "Promover sociedades pacíficas e inclusivas para el desarrollo sostenible, facilitar el acceso a la justicia para todos y construir a todos los niveles instituciones eficaces e inclusivas que rindan cuentas"@es ;
                                skos:topConceptOf <http://metadata.un.org/sdg> .


###  http://metadata.un.org/sdg/16.a
<http://metadata.un.org/sdg/16.a> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C160a01> ;
                                  <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/16> ;
                                  skos:broader <http://metadata.un.org/sdg/16> ;
                                  skos:narrower <http://metadata.un.org/sdg/C160a01> ;
                                  skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000220> ;
                                  skos:inScheme <http://metadata.un.org/sdg> ;
                                  skos:notation "16.0a"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                "16.a"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                  skos:note "Cible 16.a"@fr ,
                                            "Meta 16.a"@es ,
                                            "Target 16.a"@en ;
                                  skos:prefLabel "Appuyer, notamment dans le cadre de la coopération internationale, les institutions nationales chargées de renforcer, à tous les niveaux, les moyens de prévenir la violence et de lutter contre le terrorisme et la criminalité, en particulier dans les pays en développement"@fr ,
                                                 "Fortalecer las instituciones nacionales pertinentes, incluso mediante la cooperación internacional, para crear a todos los niveles, particularmente en los países en desarrollo, la capacidad de prevenir la violencia y combatir el terrorismo y la delincuencia"@es ,
                                                 "Strengthen relevant national institutions, including through international cooperation, for building capacity at all levels, in particular in developing countries, to prevent violence and combat terrorism and crime"@en .


###  http://metadata.un.org/sdg/16.b
<http://metadata.un.org/sdg/16.b> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C200204> ;
                                  <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/16> ;
                                  skos:broader <http://metadata.un.org/sdg/16> ;
                                  skos:narrower <http://metadata.un.org/sdg/C200204> ;
                                  skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000221> ;
                                  skos:inScheme <http://metadata.un.org/sdg> ;
                                  skos:notation "16.0b"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                "16.b"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                  skos:note "Cible 16.b"@fr ,
                                            "Meta 16.b"@es ,
                                            "Target 16.b"@en ;
                                  skos:prefLabel "Promote and enforce non-discriminatory laws and policies for sustainable development"@en ,
                                                 "Promouvoir et appliquer des lois et politiques non discriminatoires pour le développement durable"@fr ,
                                                 "Promover y aplicar leyes y políticas no discriminatorias en favor del desarrollo sostenible"@es .


