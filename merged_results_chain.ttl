                                  skos:broader <http://metadata.un.org/sdg/11> ;
                                  skos:narrower <http://metadata.un.org/sdg/C110701> ,
                                                <http://metadata.un.org/sdg/C110702> ;
                                  skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000167> ;
                                  skos:inScheme <http://metadata.un.org/sdg> ;
                                  skos:notation "11.07"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                "11.7"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                  skos:note "Cible 11.7"@fr ,
                                            "Meta 11.7"@es ,
                                            "Target 11.7"@en ;
                                  skos:prefLabel "By 2030, provide universal access to safe, inclusive and accessible, green and public spaces, in particular for women and children, older persons and persons with disabilities"@en ,
                                                 "De aquí a 2030, proporcionar acceso universal a zonas verdes y espacios públicos seguros, inclusivos y accesibles, en particular para las mujeres y los niños, las personas de edad y las personas con discapacidad"@es ,
                                                 "D’ici à 2030, assurer l’accès de tous, en particulier des femmes et des enfants, des personnes âgées et des personnes handicapées, à des espaces verts et des espaces publics sûrs"@fr .


