<http://metadata.un.org/sdg/10.4> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C100401> ;
