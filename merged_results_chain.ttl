                                 skos:narrower <http://metadata.un.org/sdg/C030601> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000091> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "03.06"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "3.6"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 3.6"@fr ,
                                           "Meta 3.6"@es ,
                                           "Target 3.6"@en ;
                                 skos:prefLabel "By 2020, halve the number of global deaths and injuries from road traffic accidents"@en ,
                                                "De aquí a 2020, reducir a la mitad el número de muertes y lesiones causadas por accidentes de tráfico en el mundo"@es ,
                                                "D’ici à 2020, diminuer de moitié à l’échelle mondiale le nombre de décès et de blessures dus à des accidents de la route"@fr .


###  http://metadata.un.org/sdg/3.7
<http://metadata.un.org/sdg/3.7> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C030701> ,
                                                                                    <http://metadata.un.org/sdg/C030702> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/3> ;
                                 <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/3913> ,
                                                                    <http://eurovoc.europa.eu/7135> ,
                                                                    <http://metadata.un.org/thesaurus/1002612> ,
                                                                    <http://metadata.un.org/thesaurus/1005493> ,
