                                 <http://purl.org/dc/terms/subject> <http://metadata.un.org/thesaurus/1001123> ,
                                                                    <http://metadata.un.org/thesaurus/1001705> ;
                                 skos:broader <http://metadata.un.org/sdg/3> ;
                                 skos:narrower <http://metadata.un.org/sdg/C030301> ,
                                               <http://metadata.un.org/sdg/C030302> ,
                                               <http://metadata.un.org/sdg/C030303> ,
                                               <http://metadata.un.org/sdg/C030304> ,
                                               <http://metadata.un.org/sdg/C030305> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000088> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "03.03"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "3.3"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 3.3"@fr ,
                                           "Meta 3.3"@es ,
                                           "Target 3.3"@en ;
                                 skos:prefLabel "By 2030, end the epidemics of AIDS, tuberculosis, malaria and neglected tropical diseases and combat hepatitis, water-borne diseases and other communicable diseases"@en ,
                                                "De aquí a 2030, poner fin a las epidemias del SIDA, la tuberculosis, la malaria y las enfermedades tropicales desatendidas y combatir la hepatitis, las enfermedades transmitidas por el agua y otras enfermedades transmisibles"@es ,
                                                "D’ici à 2030, mettre fin à l’épidémie de sida, à la tuberculose, au paludisme et aux maladies tropicales négligées et combattre l’hépatite, les maladies transmises par l’eau et autres maladies transmissibles"@fr .


###  http://metadata.un.org/sdg/3.4
<http://metadata.un.org/sdg/3.4> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C030401> ,
                                                                                    <http://metadata.un.org/sdg/C030402> ;
                                 <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/3> ;
                                 <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/1991> ,
                                                                    <http://eurovoc.europa.eu/5291> ,
                                                                    <http://metadata.un.org/thesaurus/1001518> ,
                                                                    <http://metadata.un.org/thesaurus/1004239> ;
                                 skos:broader <http://metadata.un.org/sdg/3> ;
                                 skos:narrower <http://metadata.un.org/sdg/C030401> ,
                                               <http://metadata.un.org/sdg/C030402> ;
                                 skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000089> ;
                                 skos:inScheme <http://metadata.un.org/sdg> ;
                                 skos:notation "03.04"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                               "3.4"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                 skos:note "Cible 3.4"@fr ,
                                           "Meta 3.4"@es ,
                                           "Target 3.4"@en ;
                                 skos:prefLabel "By 2030, reduce by one third premature mortality from non-communicable diseases through prevention and treatment and promote mental health and well-being"@en ,
                                                "De aquí a 2030, reducir en un tercio la mortalidad prematura por enfermedades no transmisibles mediante su prevención y tratamiento, y promover la salud mental y el bienestar"@es ,
                                                "D’ici à 2030, réduire d’un tiers, par la prévention et le traitement, le taux de mortalité prématurée due à des maladies non transmissibles et promouvoir la santé mentale et le bien-être"@fr .


###  http://metadata.un.org/sdg/3.5
<http://metadata.un.org/sdg/3.5> rdf:type owl:NamedIndividual ,
                                          <http://metadata.un.org/sdg/ontology#Target> ,
                                          skos:Concept ;
                                 <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C030501> ,
