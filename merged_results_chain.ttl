                                  skos:narrower <http://metadata.un.org/sdg/C100501> ;
                                  skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000155> ;
                                  skos:inScheme <http://metadata.un.org/sdg> ;
                                  skos:notation "10.05"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                "10.5"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                  skos:note "Cible 10.5"@fr ,
                                            "Meta 10.5"@es ,
                                            "Target 10.5"@en ;
                                  skos:prefLabel "Améliorer la réglementation et la surveillance des institutions et marchés financiers mondiaux et renforcer l’application des règles"@fr ,
                                                 "Improve the regulation and monitoring of global financial markets and institutions and strengthen the implementation of such regulations"@en ,
                                                 "Mejorar la reglamentación y vigilancia de las instituciones y los mercados financieros mundiales y fortalecer la aplicación de esos reglamentos"@es .


###  http://metadata.un.org/sdg/10.6
<http://metadata.un.org/sdg/10.6> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C200205> ;
                                  <http://metadata.un.org/sdg/ontology#isTargetOf> <http://metadata.un.org/sdg/10> ;
                                  <http://purl.org/dc/terms/subject> <http://eurovoc.europa.eu/2295> ,
                                                                     <http://metadata.un.org/thesaurus/1001613> ,
                                                                     <http://metadata.un.org/thesaurus/1002104> ,
                                                                     <http://metadata.un.org/thesaurus/1003263> ;
                                  skos:broader <http://metadata.un.org/sdg/10> ;
                                  skos:narrower <http://metadata.un.org/sdg/C200205> ;
                                  skos:exactMatch <http://purl.unep.org/sdg/SDGIO_00000156> ;
                                  skos:inScheme <http://metadata.un.org/sdg> ;
                                  skos:notation "10.06"^^<http://metadata.un.org/sdg/ontology#SDGCode> ,
                                                "10.6"^^<http://metadata.un.org/sdg/ontology#SDGCodeCompact> ;
                                  skos:note "Cible 10.6"@fr ,
                                            "Meta 10.6"@es ,
                                            "Target 10.6"@en ;
                                  skos:prefLabel "Asegurar una mayor representación e intervención de los países en desarrollo en las decisiones adoptadas por las instituciones económicas y financieras internacionales para aumentar la eficacia, fiabilidad, rendición de cuentas y legitimidad de esas instituciones"@es ,
                                                 "Ensure enhanced representation and voice for developing countries in decision-making in global international economic and financial institutions in order to deliver more effective, credible, accountable and legitimate institutions"@en ,
                                                 "Faire en sorte que les pays en développement soient davantage représentés et entendus lors de la prise de décisions dans les institutions économiques et financières internationales, afin que celles-ci soient plus efficaces, crédibles, transparentes et légitimes"@fr .


###  http://metadata.un.org/sdg/10.7
<http://metadata.un.org/sdg/10.7> rdf:type owl:NamedIndividual ,
                                           <http://metadata.un.org/sdg/ontology#Target> ,
                                           skos:Concept ;
                                  <http://metadata.un.org/sdg/ontology#hasIndicator> <http://metadata.un.org/sdg/C100701> ,
