###  https://conservationstandards.org/library-item/actions-classification#A
<https://conservationstandards.org/library-item/actions-classification#A> rdf:type owl:NamedIndividual ,
                                                                                   skos:Concept ;
                                                                          skos:definition "Actions to directly restore a target or mitigate a stress"@en ;
                                                                          skos:notation "A" ;
                                                                          skos:prefLabel "TARGET RESTORATION / STRESS REDUCTION ACTIONS"@en ;
                                                                          skos:topConceptOf <https://conservationstandards.org/library-item/actions-classification#ActionScheme> .


###  https://conservationstandards.org/library-item/actions-classification#ActionScheme
<https://conservationstandards.org/library-item/actions-classification#ActionScheme> rdf:type owl:NamedIndividual ,
                                                                                              skos:ConceptScheme ;
                                                                                     rdfs:label "CMP Actions Classification v2.0"@en .


###  https://conservationstandards.org/library-item/actions-classification#B
<https://conservationstandards.org/library-item/actions-classification#B> rdf:type owl:NamedIndividual ,
                                                                                   skos:Concept ;
                                                                          skos:definition "Actions to reduce direct threats or increase positive behaviors"@en ;
                                                                          skos:notation "B" ;
                                                                          skos:prefLabel "BEHAVORIAL CHANGE / THREAT REDUCTION ACTIONS"@en ;
                                                                          skos:topConceptOf <https://conservationstandards.org/library-item/actions-classification#ActionScheme> .


###  https://conservationstandards.org/library-item/actions-classification#C
<https://conservationstandards.org/library-item/actions-classification#C> rdf:type owl:NamedIndividual ,
                                                                                   skos:Concept ;
                                                                          skos:definition "Actions to create the conditions necessary for other conservation efforts to succeed"@en ;
                                                                          skos:notation "C" ;
                                                                          skos:prefLabel "ENABLING CONDITION ACTIONS"@en ;
                                                                          skos:topConceptOf <https://conservationstandards.org/library-item/actions-classification#ActionScheme> .


###  https://conservationstandards.org/library-item/actions-classification#OTHER
<https://conservationstandards.org/library-item/actions-classification#OTHER> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:definition "Catch-all category for unclassified actions."@en ;
                                                                              skos:notation "OTHER" ;
                                                                              skos:prefLabel "UNCLASSIFIED / OTHER"@en ;
                                                                              skos:topConceptOf <https://conservationstandards.org/library-item/actions-classification#ActionScheme> .


###  https://conservationstandards.org/library-item/actions-classification#1
<https://conservationstandards.org/library-item/actions-classification#1> rdf:type owl:NamedIndividual ,
                                                                                   skos:Concept ;
                                                                          skos:broader <https://conservationstandards.org/library-item/actions-classification#A> ;
                                                                          skos:definition "Actions directly managing or restoring sites, ecosystems and the wider environment"@en ;
                                                                          skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                          skos:notation "1" ;
                                                                          skos:prefLabel "Land / Water Management"@en .


###  https://conservationstandards.org/library-item/actions-classification#1.1
<https://conservationstandards.org/library-item/actions-classification#1.1> rdf:type owl:NamedIndividual ,
                                                                                     skos:Concept ;
                                                                            skos:broader <https://conservationstandards.org/library-item/actions-classification#1> ;
                                                                            skos:definition "Enhancing viability / mitigating stresses for sites and/or ecosystem targets, especially on a smaller scale"@en ;
                                                                            skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                            skos:notation "1.1" ;
                                                                            skos:prefLabel "Site/Area Stewardship"@en .


###  https://conservationstandards.org/library-item/actions-classification#1.2
<https://conservationstandards.org/library-item/actions-classification#1.2> rdf:type owl:NamedIndividual ,
                                                                                     skos:Concept ;
                                                                            skos:broader <https://conservationstandards.org/library-item/actions-classification#1> ;
                                                                            skos:definition "Restoring missing or severely degraded ecosystems and ecosystem functions and processes, especially on a large scale"@en ;
                                                                            skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                            skos:notation "1.2" ;
                                                                            skos:prefLabel "Ecosystem & Natural Process (Re)Creation"@en .


###  https://conservationstandards.org/library-item/actions-classification#10
<https://conservationstandards.org/library-item/actions-classification#10> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/actions-classification#C> ;
                                                                           skos:definition "Actions creating the institutions needed to support conservation work"@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                           skos:notation "10" ;
                                                                           skos:prefLabel "Institutional Development"@en .


###  https://conservationstandards.org/library-item/actions-classification#10.1
<https://conservationstandards.org/library-item/actions-classification#10.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/actions-classification#10> ;
                                                                             skos:definition "The basic work needed to establish and operate conservation organizations"@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                             skos:notation "10.1" ;
                                                                             skos:prefLabel "Internal Organizational Management & Administration"@en .


###  https://conservationstandards.org/library-item/actions-classification#10.2
<https://conservationstandards.org/library-item/actions-classification#10.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/actions-classification#10> ;
