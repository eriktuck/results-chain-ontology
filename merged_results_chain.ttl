                                                                             skos:prefLabel "Recreation & Tourism Areas"@en .


###  https://conservationstandards.org/library-item/threats-classification/#10
<https://conservationstandards.org/library-item/threats-classification/#10> rdf:type owl:NamedIndividual ,
                                                                                     skos:Concept ;
                                                                            skos:broader <https://conservationstandards.org/library-item/threats-classification/#C> ;
                                                                            skos:definition "Potentially catastrophic natural disturbances that conservation practitioners may still need to consider, particularly when managing small and/or remnant species populations or ecosystems."@en ;
                                                                            skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                            skos:notation "10" ;
                                                                            skos:prefLabel "Natural Disasters"@en .


###  https://conservationstandards.org/library-item/threats-classification/#10.1
<https://conservationstandards.org/library-item/threats-classification/#10.1> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:broader <https://conservationstandards.org/library-item/threats-classification/#10> ;
                                                                              skos:definition "Specific geological events that have potentially catastrophic effects on vulnerable species and ecosystems."@en ;
                                                                              skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                              skos:notation "10.1" ;
                                                                              skos:prefLabel "Geological Events"@en .


###  https://conservationstandards.org/library-item/threats-classification/#10.2
<https://conservationstandards.org/library-item/threats-classification/#10.2> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:broader <https://conservationstandards.org/library-item/threats-classification/#10> ;
                                                                              skos:definition "Specific weather events that have potentially catastrophic effects on vulnerable species and ecosystems."@en ;
                                                                              skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                              skos:notation "10.2" ;
                                                                              skos:prefLabel "Severe Weather Events"@en .


###  https://conservationstandards.org/library-item/threats-classification/#11
<https://conservationstandards.org/library-item/threats-classification/#11> rdf:type owl:NamedIndividual ,
                                                                                     skos:Concept ;
                                                                            skos:broader <https://conservationstandards.org/library-item/threats-classification/#C> ;
                                                                            skos:definition "Change in climate patterns resulting from increased atmospheric greenhouse gasses."@en ;
                                                                            skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                            skos:notation "11" ;
                                                                            skos:prefLabel "Climate Change"@en .


###  https://conservationstandards.org/library-item/threats-classification/#11.1
<https://conservationstandards.org/library-item/threats-classification/#11.1> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:broader <https://conservationstandards.org/library-item/threats-classification/#11> ;
                                                                              skos:definition "Broad-scale changes in the abiotic conditions of ecosystems."@en ;
                                                                              skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                              skos:notation "11.1" ;
                                                                              skos:prefLabel "Changes in Physical & Chemical Regimes"@en .


###  https://conservationstandards.org/library-item/threats-classification/#11.2
<https://conservationstandards.org/library-item/threats-classification/#11.2> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:broader <https://conservationstandards.org/library-item/threats-classification/#11> ;
                                                                              skos:definition "Broad-scale changes in temperature mean, variability, seasonality and extremes, including changes in temperature extremes, increased average summer temperature, and decreased minimum winter/spring temperature."@en ;
                                                                              skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                              skos:notation "11.2" ;
                                                                              skos:prefLabel "Changes in Temperature Regimes"@en .


###  https://conservationstandards.org/library-item/threats-classification/#11.3
<https://conservationstandards.org/library-item/threats-classification/#11.3> rdf:type owl:NamedIndividual ,
                                                                                       skos:Concept ;
                                                                              skos:broader <https://conservationstandards.org/library-item/threats-classification/#11> ;
                                                                              skos:definition "Broad-scale changes in precipitation mean, variability, seasonality, and extremes, including decreased or increased precipitation, changes in timing of precipitation, changes in form of precipitation (eg snow vs rain), changes in evapotranspiration rates and hydrological cycles, and droughts and floods."@en ;
                                                                              skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                              skos:notation "11.3" ;
                                                                              skos:prefLabel "Changes in Precipitation & Hydrological Regimes"@en .


###  https://conservationstandards.org/library-item/threats-classification/#12
<https://conservationstandards.org/library-item/threats-classification/#12> rdf:type owl:NamedIndividual ,
                                                                                     skos:Concept ;
                                                                            skos:broader <https://conservationstandards.org/library-item/threats-classification/#C> ;
                                                                            skos:definition "Threats that cannot be identified."@en ;
                                                                            skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                            skos:notation "12" ;
                                                                            skos:prefLabel "Unknown Threats"@en .


###  https://conservationstandards.org/library-item/threats-classification/#2
<https://conservationstandards.org/library-item/threats-classification/#2> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#A> ;
                                                                           skos:definition "Farming and ranching including agricultural expansion, intensification, or practices with a spatial footprint; includes tree plantations, mariculture, and aquaculture."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "2" ;
                                                                           skos:prefLabel "Agriculture & Aquaculture"@en .


###  https://conservationstandards.org/library-item/threats-classification/#2.1
<https://conservationstandards.org/library-item/threats-classification/#2.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#2> ;
                                                                             skos:definition "Crops planted for food, fodder, fiber, fuel, or other uses."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "2.1" ;
                                                                             skos:prefLabel "Annual & Perennial Non-Timber Crops"@en .


###  https://conservationstandards.org/library-item/threats-classification/#2.2
<https://conservationstandards.org/library-item/threats-classification/#2.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#2> ;
                                                                             skos:definition "Stands of trees planted for timber or fiber outside of natural forests, often with non-native species."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "2.2" ;
                                                                             skos:prefLabel "Wood & Pulp Plantations"@en .


###  https://conservationstandards.org/library-item/threats-classification/#2.3
<https://conservationstandards.org/library-item/threats-classification/#2.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#2> ;
                                                                             skos:definition "Domestic terrestrial animals raised in one location on farmed or non-local resources (farming); also domestic or semidomesticated animals allowed to roam in semi-natural areas (ranching) or the wild and supported by natural habitats (herding)."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "2.3" ;
                                                                             skos:prefLabel "Terrestrial Animal Farming, Ranching & Herding"@en .


###  https://conservationstandards.org/library-item/threats-classification/#2.4
<https://conservationstandards.org/library-item/threats-classification/#2.4> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#2> ;
                                                                             skos:definition "Aquatic species raised for harvest in artificial water bodies (analogous to terrestrial 'farming'), enclosures in natural waters (analogous to 'ranching'), or unenclosed natural waters (analogous to 'herding')."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "2.4" ;
                                                                             skos:prefLabel "Marine & Freshwater Aquaculture"@en .


