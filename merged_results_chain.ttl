                                                                             skos:inScheme <https://conservationstandards.org/library-item/actions-classification#ActionScheme> ;
                                                                             skos:notation "10.2" ;
                                                                             skos:prefLabel "External Organizational Development & Support"@en .


###  https://conservationstandards.org/library-item/actions-classification#10.3
<https://conservationstandards.org/library-item/actions-classification#10.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/actions-classification#10> ;
