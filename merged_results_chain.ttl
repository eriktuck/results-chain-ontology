<https://conservationstandards.org/library-item/threats-classification/#3.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#3> ;
                                                                             skos:definition "Exploring for and developing and producing renewable energy."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "3.3" ;
                                                                             skos:prefLabel "Renewable Energy"@en .


