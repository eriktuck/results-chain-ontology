<https://conservationstandards.org/library-item/threats-classification/#4> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#A> ;
                                                                           skos:definition "Linear infrastructure such as long, narrow service or transport corridors including the effects associated with their use (e.g. mortality from vehicle collisions, restriction of species movement)."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "4" ;
                                                                           skos:prefLabel "Transportation, Service & Security Corridors"@en .


###  https://conservationstandards.org/library-item/threats-classification/#4.1
<https://conservationstandards.org/library-item/threats-classification/#4.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#4> ;
                                                                             skos:definition "Transport on roadways and dedicated tracks."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "4.1" ;
                                                                             skos:prefLabel "Roads, Trails & Railroads"@en .


###  https://conservationstandards.org/library-item/threats-classification/#4.2
<https://conservationstandards.org/library-item/threats-classification/#4.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#4> ;
                                                                             skos:definition "Transport of energy & resources."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "4.2" ;
                                                                             skos:prefLabel "Utility & Service Lines"@en .


###  https://conservationstandards.org/library-item/threats-classification/#4.3
<https://conservationstandards.org/library-item/threats-classification/#4.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#4> ;
                                                                             skos:definition "Transport on and in freshwater and ocean waterways."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "4.3" ;
                                                                             skos:prefLabel "Shipping Lanes"@en .


###  https://conservationstandards.org/library-item/threats-classification/#4.4
<https://conservationstandards.org/library-item/threats-classification/#4.4> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#4> ;
                                                                             skos:definition "Air and space transport and other activities."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "4.4" ;
                                                                             skos:prefLabel "Atmospheric & Space Activities"@en .


###  https://conservationstandards.org/library-item/threats-classification/#4.5
<https://conservationstandards.org/library-item/threats-classification/#4.5> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#4> ;
                                                                             skos:definition "Barriers to movement."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "4.5" ;
                                                                             skos:prefLabel "Fencing & Walls"@en .


###  https://conservationstandards.org/library-item/threats-classification/#5
<https://conservationstandards.org/library-item/threats-classification/#5> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#B> ;
                                                                           skos:definition "Consumptive use of \"wild\" biological resources including deliberate and unintentional harvesting effects as well as persecution of specific species."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "5" ;
                                                                           skos:prefLabel "Biological Resource Use & Control"@en .


###  https://conservationstandards.org/library-item/threats-classification/#5.1
<https://conservationstandards.org/library-item/threats-classification/#5.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#5> ;
                                                                             skos:definition "Hunting or trapping terrestrial wild animals for commercial, recreation, subsistence, research, or cultural purposes, or killing them for persecution or control reasons; includes non-lethal animal product harvesting and accidental mortality/bycatch."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "5.1" ;
                                                                             skos:prefLabel "Hunting, Collecting & Controlling Terrestrial Animals"@en .


###  https://conservationstandards.org/library-item/threats-classification/#5.2
<https://conservationstandards.org/library-item/threats-classification/#5.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#5> ;
                                                                             skos:definition "Harvesting plants, fungi, and other non-timber/non-animal products for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "5.2" ;
                                                                             skos:prefLabel "Gathering, Harvesting & Controlling Terrestrial Plants & Fungi"@en .


###  https://conservationstandards.org/library-item/threats-classification/#5.3
<https://conservationstandards.org/library-item/threats-classification/#5.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#5> ;
                                                                             skos:definition "Harvesting trees and other woody vegetation for timber, fiber, or fuel, including site preparation and other forestry management practices; includes non-lethal coppicing and accidental mortality/bycatch."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "5.3" ;
                                                                             skos:prefLabel "Logging, Harvesting & Controlling Trees"@en .


###  https://conservationstandards.org/library-item/threats-classification/#5.4
<https://conservationstandards.org/library-item/threats-classification/#5.4> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#5> ;
                                                                             skos:definition "Harvesting aquatic wild animals or plants for commercial, recreation, subsistence, research, or cultural purposes, or persecution or control reasons; includes non-lethal product harvesting and accidental mortality/bycatch."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "5.4" ;
                                                                             skos:prefLabel "Fishing, Harvesting & Controlling Aquatic Species"@en .


###  https://conservationstandards.org/library-item/threats-classification/#6
<https://conservationstandards.org/library-item/threats-classification/#6> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#B> ;
                                                                           skos:definition "Human activities that alter, disturb, and destroy ecosystems and species associated with non-consumptive uses of biological areas and resources."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "6" ;
                                                                           skos:prefLabel "Human Intrusions & Disturbances"@en .


###  https://conservationstandards.org/library-item/threats-classification/#6.1
<https://conservationstandards.org/library-item/threats-classification/#6.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#6> ;
                                                                             skos:definition "People spending time in natural areas or traveling in vehicles outside of established transport corridors, usually for recreational reasons."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "6.1" ;
                                                                             skos:prefLabel "Recreational Activities"@en .


###  https://conservationstandards.org/library-item/threats-classification/#6.2
<https://conservationstandards.org/library-item/threats-classification/#6.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#6> ;
                                                                             skos:definition "Actions in natural areas by formal or paramilitary forces without a permanent footprint."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "6.2" ;
                                                                             skos:prefLabel "Conflict, Civil Unrest & Security Activities"@en .


###  https://conservationstandards.org/library-item/threats-classification/#6.3
<https://conservationstandards.org/library-item/threats-classification/#6.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#6> ;
                                                                             skos:definition "People spending time in or traveling in natural environments for reasons other than recreation or conflict/security activities"@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "6.3" ;
                                                                             skos:prefLabel "Other Human Disturbances"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7
<https://conservationstandards.org/library-item/threats-classification/#7> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#B> ;
                                                                           skos:definition "Human actions that modify ecosystem structures, composition, or regimes, generally to deliberately improve human welfare or benefit certain species. This category includes both construction of permanent or long-term structures and their operations as well as more transitory management practices."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "7" ;
                                                                           skos:prefLabel "Natural System Management & Modifications"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.1
<https://conservationstandards.org/library-item/threats-classification/#7.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Management actions that either suppress or increase fire frequency and/or intensity."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.1" ;
                                                                             skos:prefLabel "Fire & Fire Management"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.2
<https://conservationstandards.org/library-item/threats-classification/#7.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Management actions that modify water levels, flows, and chemistry."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.2" ;
                                                                             skos:prefLabel "Dams & Water Management / Use"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.3
<https://conservationstandards.org/library-item/threats-classification/#7.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Management actions that modify the geophysical environment and/or change sediment regimes."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.3" ;
                                                                             skos:prefLabel "Earth & Sediment Management"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.4
<https://conservationstandards.org/library-item/threats-classification/#7.4> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Management actions that modify atmospheric structure and processes."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.4" ;
                                                                             skos:prefLabel "Weather & Climate Management"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.5
<https://conservationstandards.org/library-item/threats-classification/#7.5> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Management actions that modify biotic systems including conservation actions that may have detrimental impacts on other non-targeted species or ecosystems."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.5" ;
                                                                             skos:prefLabel "Biological System Management"@en .


###  https://conservationstandards.org/library-item/threats-classification/#7.6
<https://conservationstandards.org/library-item/threats-classification/#7.6> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#7> ;
                                                                             skos:definition "Absence or reduction of current or historical management regimes important for maintaining desired key ecological attributes of ecosystems or species. Includes regimes historically maintained by protected area staff, farmers and ranchers, indigenous peoples, private landowners, or any other resource manager."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "7.6" ;
                                                                             skos:prefLabel "Removing / Reducing Human Management"@en .


###  https://conservationstandards.org/library-item/threats-classification/#8
<https://conservationstandards.org/library-item/threats-classification/#8> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#C> ;
                                                                           skos:definition "Threats from non-native and native plants, animals, pathogens/microbes, or genetic materials that have or are predicted to have harmful effects on biodiversity following their introduction, spread and/or increase in abundance or virulence."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "8" ;
                                                                           skos:prefLabel "Invasive / Other Problematic Species, Genes & Pathogens"@en .


###  https://conservationstandards.org/library-item/threats-classification/#8.1
<https://conservationstandards.org/library-item/threats-classification/#8.1> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#8> ;
                                                                             skos:definition "Harmful plants, animals, and other species not originally found within the ecosystem(s) in question and directly or indirectly introduced and spread into it by human activities."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "8.1" ;
                                                                             skos:prefLabel "Invasive Non-Native / Alien Species"@en .


###  https://conservationstandards.org/library-item/threats-classification/#8.2
<https://conservationstandards.org/library-item/threats-classification/#8.2> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#8> ;
                                                                             skos:definition "Harmful plants, animals, and other species that are originally found within the ecosystem(s) in question, but have become “out-of-balance” or “released” directly or indirectly due to human activities."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "8.2" ;
                                                                             skos:prefLabel "Problematic Native Species"@en .


###  https://conservationstandards.org/library-item/threats-classification/#8.3
<https://conservationstandards.org/library-item/threats-classification/#8.3> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#8> ;
                                                                             skos:definition "Human caused introduction of natural or synthetic genes into species in natural ecosystems."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "8.3" ;
                                                                             skos:prefLabel "Introduced Genetic Material"@en .


###  https://conservationstandards.org/library-item/threats-classification/#8.4
<https://conservationstandards.org/library-item/threats-classification/#8.4> rdf:type owl:NamedIndividual ,
                                                                                      skos:Concept ;
                                                                             skos:broader <https://conservationstandards.org/library-item/threats-classification/#8> ;
                                                                             skos:definition "Harmful native and non-native agents that cause disease or illness to a host species, including bacteria, viruses, prions, fungi, and other microorganisms."@en ;
                                                                             skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                             skos:notation "8.4" ;
                                                                             skos:prefLabel "Pathogens"@en .


###  https://conservationstandards.org/library-item/threats-classification/#9
<https://conservationstandards.org/library-item/threats-classification/#9> rdf:type owl:NamedIndividual ,
                                                                                    skos:Concept ;
                                                                           skos:broader <https://conservationstandards.org/library-item/threats-classification/#C> ;
                                                                           skos:definition "Introduction of exotic and/or excess materials or energy from point and nonpoint sources."@en ;
                                                                           skos:inScheme <https://conservationstandards.org/library-item/threats-classification/#ThreatScheme> ;
                                                                           skos:notation "9" ;
                                                                           skos:prefLabel "Pollution"@en .


###  https://conservationstandards.org/library-item/threats-classification/#9.1
